<?xml version="1.0" encoding="UTF-8"?>
<entity-facade-xml>
    <!-- ============================================================
         SHARED / UTILITY SEED DATA
         Entity-specific seed data has been moved to inline <seed-data>
         sections in each entity definition file.
    ============================================================ -->

    <!-- TradeSanctionsStatus: used by TradeParty (shared across entities) -->
    <moqui.basic.EnumerationType enumTypeId="TradeSanctionsStatus" description="Sanctions Screening Status"/>
    <moqui.basic.Enumeration enumId="SANCTION_PENDING" enumTypeId="TradeSanctionsStatus" description="Pending Screening"/>
    <moqui.basic.Enumeration enumId="SANCTION_CLEAR" enumTypeId="TradeSanctionsStatus" description="Clear / Sanctioned Name Not Found"/>
    <moqui.basic.Enumeration enumId="SANCTION_BLOCKED" enumTypeId="TradeSanctionsStatus" description="Blocked / Positive Match Found"/>

    <!-- TradeShipmentOption: shared across ImportLetterOfCredit and ImportLcAmendment -->
    <moqui.basic.EnumerationType enumTypeId="TradeShipmentOption" description="Shipment Options (Partial, Transhipment)"/>
    <moqui.basic.Enumeration enumId="ALLOWED" enumTypeId="TradeShipmentOption" description="Allowed"/>
    <moqui.basic.Enumeration enumId="NOT_ALLOWED" enumTypeId="TradeShipmentOption" description="Not Allowed"/>
    <moqui.basic.Enumeration enumId="CONDITIONAL" enumTypeId="TradeShipmentOption" description="Conditional"/>

    <!-- TradeConfirmation: shared across ImportLetterOfCredit and ImportLcAmendment -->
    <moqui.basic.EnumerationType enumTypeId="TradeConfirmation" description="LC Confirmation Options"/>
    <moqui.basic.Enumeration enumId="CONFIRMED" enumTypeId="TradeConfirmation" description="Confirmed"/>
    <moqui.basic.Enumeration enumId="CONF_CONFIRMED" enumTypeId="TradeConfirmation" description="Confirmed"/>
    <moqui.basic.Enumeration enumId="WITHOUT" enumTypeId="TradeConfirmation" description="Without Confirmation"/>
    <moqui.basic.Enumeration enumId="CONF_WITHOUT" enumTypeId="TradeConfirmation" description="Without Confirmation"/>
    <moqui.basic.Enumeration enumId="MAY_ADD" enumTypeId="TradeConfirmation" description="May Add Confirmation"/>
    <moqui.basic.Enumeration enumId="CONF_MAY_ADD" enumTypeId="TradeConfirmation" description="May Add Confirmation"/>

    <!-- TradeLaunchAction: used by TradeTransactionAudit -->
    <moqui.basic.EnumerationType enumTypeId="TradeLaunchAction" description="Trade Lifecycle Actions"/>
    <moqui.basic.Enumeration enumId="AUDIT_HOLD" enumTypeId="TradeLaunchAction" description="Compliance Hold Applied"/>
    <moqui.basic.Enumeration enumId="AUDIT_RELEASE" enumTypeId="TradeLaunchAction" description="Compliance Hold Released"/>
    <moqui.basic.Enumeration enumId="MAKER_UPDATE" enumTypeId="TradeLaunchAction" description="Maker Update"/>
    <moqui.basic.Enumeration enumId="MAKER_COMMIT" enumTypeId="TradeLaunchAction" description="Maker Commit"/>

    <!-- Bank Configuration Records (shared) -->
    <trade.common.TradeConfig configId="ISSUING_BANK_BIC" configValue="VIETBANK1XXX" description="Issuing bank SWIFT BIC for message headers"/>
    <trade.common.TradeConfig configId="NOSTRO_ACCOUNT_USD" configValue="001-234567-USD" description="USD Nostro account for MT202 routing"/>

    <!-- Number Sequences (shared) -->
    <trade.common.NumberSequence sequenceId="SEQ_IMP_LC" lastNumber="1000" description="Import LC Numbering"/>
    <trade.common.NumberSequence sequenceId="SEQ_TXN" lastNumber="5000" description="Trade Transaction Numbering"/>

    <!-- Public Holidays (shared) -->
    <trade.PublicHoliday holidayDate="2026-04-27" description="SLA Test Holiday"/>

    <!-- SwiftMessageStatus -->
    <moqui.basic.StatusType statusTypeId="SwiftMessageStatus" description="SWIFT Message Processing Statuses"/>
    <moqui.basic.StatusItem statusId="SWIFT_MSG_DRAFT" description="Draft" statusTypeId="SwiftMessageStatus"/>
    <moqui.basic.StatusItem statusId="SWIFT_MSG_ACTIVE" description="Active" statusTypeId="SwiftMessageStatus"/>

    <!-- Additional LC Statuses -->
    <moqui.basic.StatusItem statusId="LC_AMENDED" statusTypeId="TradeLcBusinessState" description="Amended"/>

    <!-- TradePartyType -->
    <moqui.basic.EnumerationType enumTypeId="TradePartyType" description="Trade Party Types"/>
    <moqui.basic.Enumeration enumId="PTY_COMMERCIAL" enumTypeId="TradePartyType" description="Commercial Party"/>
    <moqui.basic.Enumeration enumId="PTY_BANK" enumTypeId="TradePartyType" description="Bank Party"/>
    <moqui.basic.Enumeration enumId="PTY_PERSON" enumTypeId="TradePartyType" description="Individual Person"/>

    <!-- TradePartyKycStatus -->
    <moqui.basic.StatusType statusTypeId="TradePartyKycStatus" description="Party KYC Statuses"/>
    <moqui.basic.StatusItem statusId="KYC_ACTIVE" statusTypeId="TradePartyKycStatus" description="Active"/>
    <moqui.basic.StatusItem statusId="KYC_EXPIRED" statusTypeId="TradePartyKycStatus" description="Expired"/>
    <moqui.basic.StatusItem statusId="KYC_NONE" statusTypeId="TradePartyKycStatus" description="None"/>

    <!-- TradePartySanctionsStatus -->
    <moqui.basic.StatusType statusTypeId="TradePartySanctionsStatus" description="Party Sanctions Statuses"/>
    <moqui.basic.StatusItem statusId="SNC_CLEAR" statusTypeId="TradePartySanctionsStatus" description="Clear"/>
    <moqui.basic.StatusItem statusId="SNC_PENDING" statusTypeId="TradePartySanctionsStatus" description="Pending"/>
    <moqui.basic.StatusItem statusId="SNC_BLOCKED" statusTypeId="TradePartySanctionsStatus" description="Blocked"/>

    <!-- TradeLcType -->
    <moqui.basic.EnumerationType enumTypeId="TradeLcType" description="LC Types"/>
    <moqui.basic.Enumeration enumId="LCT_IRREVOCABLE" enumTypeId="TradeLcType" description="IRREVOCABLE"/>
    <moqui.basic.Enumeration enumId="LCT_REVOCABLE" enumTypeId="TradeLcType" description="REVOCABLE"/>
    <moqui.basic.Enumeration enumId="LCT_STANDBY" enumTypeId="TradeLcType" description="STANDBY"/>
    <moqui.basic.Enumeration enumId="LCT_IRREVOCABLE_TRANSFERABLE" enumTypeId="TradeLcType" description="IRREVOCABLE TRANSFERABLE"/>
    <moqui.basic.Enumeration enumId="LCT_REVOCABLE_TRANSFERABLE" enumTypeId="TradeLcType" description="REVOCABLE TRANSFERABLE"/>
    <moqui.basic.Enumeration enumId="LCT_SIGHT" enumTypeId="TradeLcType" description="SIGHT"/>
    <moqui.basic.Enumeration enumId="LCT_USANCE" enumTypeId="TradeLcType" description="USANCE"/>

    <!-- TradeChargeAllocation -->
    <moqui.basic.EnumerationType enumTypeId="TradeChargeAllocation" description="Charge Allocation Options"/>
    <moqui.basic.Enumeration enumId="CHG_SHARED" enumTypeId="TradeChargeAllocation" description="Shared (Applicant and Beneficiary)"/>
    <moqui.basic.Enumeration enumId="CHG_APPLICANT" enumTypeId="TradeChargeAllocation" description="All Charges on Applicant"/>
    <moqui.basic.Enumeration enumId="CHG_BENEFICIARY" enumTypeId="TradeChargeAllocation" description="All Charges on Beneficiary"/>

    <!-- TradeAvailableBy -->
    <moqui.basic.EnumerationType enumTypeId="TradeAvailableBy" description="LC Availability Methods (Tag 41a)"/>
    <moqui.basic.Enumeration enumId="AVB_BY_PAYMENT" enumTypeId="TradeAvailableBy" description="BY PAYMENT"/>
    <moqui.basic.Enumeration enumId="AVB_BY_ACCEPTANCE" enumTypeId="TradeAvailableBy" description="BY ACCEPTANCE"/>
    <moqui.basic.Enumeration enumId="AVB_BY_NEGOTIATION" enumTypeId="TradeAvailableBy" description="BY NEGOTIATION"/>
    <moqui.basic.Enumeration enumId="AVB_BY_DEF_PAYMENT" enumTypeId="TradeAvailableBy" description="BY DEF PAYMENT"/>
    <moqui.basic.Enumeration enumId="AVB_BY_MIXED_PAYMENT" enumTypeId="TradeAvailableBy" description="BY MIXED PAYMENT"/>
    <moqui.basic.Enumeration enumId="AVB_BY_SIGHT_PAYMENT" enumTypeId="TradeAvailableBy" description="BY SIGHT PAYMENT"/>

    <!-- TradeLcAvailWith -->
    <moqui.basic.EnumerationType enumTypeId="TradeLcAvailWith" description="Available With Bank Types"/>
    <moqui.basic.Enumeration enumId="AW_ANY_BANK" enumTypeId="TradeLcAvailWith" description="Any Bank"/>
    <moqui.basic.Enumeration enumId="AW_SPECIFIC_BANK" enumTypeId="TradeLcAvailWith" description="Specific Bank"/>

    <!-- ApplicableRules -->
    <moqui.basic.EnumerationType enumTypeId="ApplicableRules" description="Applicable Rules (Tag 40E/40F)"/>
    <moqui.basic.Enumeration enumId="APR_UCP_LATEST" enumTypeId="ApplicableRules" description="UCP LATEST VERSION"/>
    <moqui.basic.Enumeration enumId="APR_EUCP_LATEST" enumTypeId="ApplicableRules" description="EUCP LATEST VERSION"/>
    <moqui.basic.Enumeration enumId="APR_UCPDC_600" enumTypeId="ApplicableRules" description="UCP 600"/>
    <moqui.basic.Enumeration enumId="APR_ISP_LATEST" enumTypeId="ApplicableRules" description="ISP LATEST VERSION"/>
    <moqui.basic.Enumeration enumId="APR_OTHER" enumTypeId="ApplicableRules" description="OTHER"/>

    <!-- ReimbursingCharges -->
    <moqui.basic.EnumerationType enumTypeId="TradeReimbCharges" description="Reimbursement Charge Options"/>
    <moqui.basic.Enumeration enumId="RMB_OUR" enumTypeId="TradeReimbCharges" description="OUR"/>
    <moqui.basic.Enumeration enumId="RMB_BEN" enumTypeId="TradeReimbCharges" description="BEN"/>

    <!-- TradeMarginType -->
    <moqui.basic.EnumerationType enumTypeId="TradeMarginType" description="Margin Requirement Types"/>
    <moqui.basic.Enumeration enumId="MARG_NONE" enumTypeId="TradeMarginType" description="None"/>
    <moqui.basic.Enumeration enumId="MARG_CASH" enumTypeId="TradeMarginType" description="Cash Margin"/>
    <moqui.basic.Enumeration enumId="MARG_LOMBARD" enumTypeId="TradeMarginType" description="Lombard / Pledged Assets"/>

    <!-- Inbound SWIFT: Inbox Status -->
    <moqui.basic.EnumerationType enumTypeId="InboxStatus" description="Inbound SWIFT Inbox Statuses"/>
    <moqui.basic.Enumeration enumId="INBOX_UNREAD" enumTypeId="InboxStatus" description="Unread"/>
    <moqui.basic.Enumeration enumId="INBOX_IN_PROGRESS" enumTypeId="InboxStatus" description="In Progress"/>
    <moqui.basic.Enumeration enumId="INBOX_PROCESSED" enumTypeId="InboxStatus" description="Processed"/>
    <moqui.basic.Enumeration enumId="INBOX_ORPHANED" enumTypeId="InboxStatus" description="Orphaned"/>

    <!-- Inbound SWIFT: Correlation Status -->
    <moqui.basic.EnumerationType enumTypeId="CorrelationStatus" description="Inbound SWIFT Correlation Statuses"/>
    <moqui.basic.Enumeration enumId="INBOX_AUTO_MATCH" enumTypeId="CorrelationStatus" description="Auto-Matched"/>
    <moqui.basic.Enumeration enumId="INBOX_MANUAL_MATCH" enumTypeId="CorrelationStatus" description="Manual Match"/>
    <moqui.basic.Enumeration enumId="INBOX_ORPHANED" enumTypeId="CorrelationStatus" description="Orphaned"/>
</entity-facade-xml>