<?xml version="1.0" encoding="UTF-8"?>
<resource xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/rest-api-3.xsd"
          name="trade" displayName="Trade Finance REST API" version="1.0.0" require-authentication="false">
    <resource name="login">
        <method type="post">
            <service name="org.moqui.impl.UserServices.login#UserAccount"/>
        </method>
    </resource>
    <resource name="logout">
        <method type="post">
            <service name="trade.UserAccountServices.logout#User"/>
        </method>
    </resource>
    <resource name="current-user">
        <method type="get">
            <service name="trade.UserAccountServices.get#CurrentUser"/>
        </method>
    </resource>
    <resource name="change-password">
        <method type="post">
            <service name="trade.UserAccountServices.change#OwnPassword"/>
        </method>
    </resource>
    <resource name="kpis">
        <method type="get">
            <service name="trade.importlc.ImportLcServices.get#Kpis"/>
        </method>
    </resource>
    <resource name="import-lc">
        <method type="get"><service name="trade.importlc.ImportLcServices.get#ImportLetterOfCreditList"/></method>
        <method type="post"><service name="trade.importlc.ImportLcServices.create#ImportLetterOfCredit"/></method>
        <resource name="validate">
            <method type="post"><service name="trade.importlc.ImportLcValidationServices.validate#SwiftFields"/></method>
        </resource>
        <id name="instrumentId" require-authentication="false">
            <method type="get"><service name="trade.importlc.ImportLcServices.get#ImportLetterOfCredit"/></method>
            <method type="post"><service name="trade.importlc.ImportLcServices.update#ImportLetterOfCredit"/></method>
            <resource name="amendments">
                <method type="post"><service name="trade.importlc.ImportLcServices.create#Amendment"/></method>
            </resource>
            <resource name="presentations">
                <method type="post"><service name="trade.TradeCommonServices.create#Presentation"/></method>
                <id name="presentationId">
                    <resource name="waiver">
                        <method type="patch"><service name="trade.importlc.ImportLcServices.update#PresentationWaiver"/></method>
                    </resource>
                </id>
            </resource>
            <resource name="settlements">
                <method type="post"><service name="trade.TradeAccountingServices.create#ImportLcSettlement"/></method>
            </resource>
            <resource name="shipping-guarantees">
                <method type="post"><service name="trade.TradeCommonServices.create#ShippingGuarantee"/></method>
            </resource>
            <resource name="cancel">
                <method type="post"><service name="trade.TradeCommonServices.update#Cancellation"/></method>
            </resource>
        </id>
    </resource>
    <resource name="authorize">
        <method type="post"><service name="trade.AuthorizationServices.authorize#Instrument"/></method>
    </resource>
    <resource name="reject">
        <method type="post"><service name="trade.AuthorizationServices.reject#Instrument"/></method>
    </resource>
    <resource name="approvals">
        <method type="get"><service name="trade.AuthorizationServices.get#PendingApprovals"/></method>
    </resource>
    <resource name="standard-clauses">
        <method type="get"><service name="trade.TradeClauseServices.get#StandardClauses"/></method>
    </resource>

    <resource name="common">
        <resource name="transactions">
            <method type="get"><service name="trade.TradeCommonServices.get#TradeTransactions"/></method>
        </resource>
        <resource name="audit-logs">
            <method type="get"><service name="trade.TradeCommonServices.get#GlobalTransactionLogs"/></method>
        </resource>
    </resource>

    <resource name="transaction">
        <id name="transactionId">
            <method type="get"><service name="trade.TradeCommonServices.get#TradeTransaction"/></method>
        </id>
    </resource>

    <resource name="audit-logs">
        <method type="get"><service name="trade.AdminServices.get#TradeAuditLogs"/></method>
    </resource>

    <resource name="product-config">
        <method type="post"><service name="trade.AdminServices.update#TradeProductConfig"/></method>
    </resource>

    <resource name="fee-configurations">
        <method type="get"><service name="trade.MasterDataServices.get#FeeConfigurations"/></method>
    </resource>

    <resource name="product-catalog">
        <method type="get"><service name="trade.MasterDataServices.get#ProductCatalog"/></method>
    </resource>

    <resource name="parties">
        <method type="get"><service name="trade.MasterDataServices.get#Parties"/></method>
        <method type="post"><service name="trade.TradeCommonServices.create#TradeParty"/></method>
        <id name="partyId">
            <method type="get"><service name="trade.TradeCommonServices.get#TradeParty"/></method>
            <method type="post"><service name="trade.TradeCommonServices.update#TradeParty"/></method>
        </id>
    </resource>

    <resource name="authority-profiles">
        <method type="get"><service name="trade.MasterDataServices.get#UserAuthorityProfiles"/></method>
        <id name="userAuthorityId">
            <method type="post"><service name="trade.MasterDataServices.update#UserAuthorityProfile"/></method>
        </id>
    </resource>

    <resource name="exposure-data">
        <method type="get"><service name="trade.LimitServices.get#ExposureData"/></method>
    </resource>

    <resource name="facilities">
        <parameter name="facilityId"/>
        <method type="get"><service name="trade.LimitServices.get#FacilityDetail"/></method>
        <resource name="customer">
            <method type="get"><service name="trade.LimitServices.get#CustomerFacilities"/></method>
        </resource>
    </resource>
    <resource name="instrument">
        <id name="instrumentId">
            <method type="get"><service name="trade.TradeCommonServices.get#Instrument"/></method>
            <resource name="audit-logs">
                <method type="get"><service name="trade.AdminServices.get#TradeAuditLogs"/></method>
            </resource>
            <resource name="transactions">
                <method type="get"><service name="trade.TradeCommonServices.get#InstrumentTransactions"/></method>
            </resource>
        </id>
    </resource>
    <resource name="master-data">
        <resource name="load">
            <method type="post"><service name="trade.TradeCommonServices.load#MasterData"/></method>
        </resource>
    </resource>
</resource>