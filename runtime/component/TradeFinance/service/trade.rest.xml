<?xml version="1.0" encoding="UTF-8"?>
<resource xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/rest-api-3.xsd"
          name="trade" displayName="Trade Finance REST API" version="1.0.0" require-authentication="false">
    <resource name="login">
        <method type="post">
            <service name="org.moqui.impl.UserServices.login#UserAccount"/>
        </method>
    </resource>
    <resource name="logout">
        <method type="post">
            <service name="trade.UserAccountServices.logout#User"/>
        </method>
    </resource>
    <resource name="current-user">
        <method type="get">
            <service name="trade.UserAccountServices.get#CurrentUser"/>
        </method>
    </resource>
    <resource name="change-password">
        <method type="post">
            <service name="trade.UserAccountServices.change#OwnPassword"/>
        </method>
    </resource>
    <resource name="kpis">
        <method type="get">
            <service name="trade.importlc.ImportLcServices.get#Kpis"/>
        </method>
    </resource>
    <resource name="import-lc">
        <method type="get"><service name="trade.importlc.ImportLcServices.get#ImportLetterOfCreditList"/></method>
        <method type="post"><service name="trade.importlc.ImportLcServices.create#ImportLetterOfCredit"/></method>
        <resource name="validate">
            <method type="post"><service name="trade.importlc.ImportLcValidationServices.validate#SwiftFields"/></method>
        </resource>
        <id name="instrumentId" require-authentication="false">
            <method type="get"><service name="trade.importlc.ImportLcServices.get#ImportLetterOfCredit"/></method>
            <method type="post"><service name="trade.importlc.ImportLcServices.update#ImportLetterOfCredit"/></method>
            <resource name="amendment">
                <resource name="external">
                    <method type="post"><service name="trade.importlc.ImportLcServices.create#ExternalAmendment"/></method>
                </resource>
                <resource name="internal">
                    <method type="post"><service name="trade.importlc.ImportLcServices.create#InternalAmendment"/></method>
                </resource>
                <id name="amendmentId">
                    <method type="get"><service name="trade.importlc.ImportLcServices.get#Amendment"/></method>
                    <method type="put"><service name="trade.importlc.ImportLcServices.update#Amendment"/></method>
                    <resource name="submit">
                        <method type="post"><service name="trade.importlc.ImportLcServices.submit#Amendment"/></method>
                    </resource>
                    <resource name="authorize">
                        <method type="post"><service name="trade.importlc.ImportLcServices.authorize#Amendment"/></method>
                    </resource>
                    <resource name="accept">
                        <method type="post"><service name="trade.importlc.ImportLcServices.accept#Amendment"/></method>
                    </resource>
                    <resource name="reject">
                        <method type="post"><service name="trade.importlc.ImportLcServices.reject#Amendment"/></method>
                    </resource>
                </id>
            </resource>
            <resource name="presentation">
                <method type="post"><service name="trade.TradeCommonServices.create#Presentation"/></method>
                <id name="presentationId">
                    <method type="put"><service name="trade.TradeCommonServices.update#Presentation"/></method>
                    <resource name="waiver">
                        <method type="patch"><service name="trade.importlc.ImportLcServices.update#PresentationWaiver"/></method>
                    </resource>
                    <resource name="submit">
                        <method type="post"><service name="trade.TradeCommonServices.submit#Presentation"/></method>
                    </resource>
                </id>
            </resource>
            <resource name="settlement">
                <method type="post"><service name="trade.TradeAccountingServices.create#ImportLcSettlement"/></method>
                <id name="settlementId">
                    <method type="put"><service name="trade.TradeAccountingServices.update#ImportLcSettlement"/></method>
                    <resource name="submit">
                        <method type="post"><service name="trade.TradeAccountingServices.submit#ImportLcSettlement"/></method>
                    </resource>
                </id>
            </resource>
            <resource name="shipping-guarantee">
                <method type="post"><service name="trade.TradeCommonServices.create#ShippingGuarantee"/></method>
                <id name="guaranteeId">
                    <method type="put"><service name="trade.TradeCommonServices.update#ShippingGuarantee"/></method>
                    <resource name="submit">
                        <method type="post"><service name="trade.TradeCommonServices.submit#ShippingGuarantee"/></method>
                    </resource>
                </id>
            </resource>
            <resource name="cancellation">
                <method type="post"><service name="trade.TradeCommonServices.create#Cancellation"/></method>
                <id name="transactionId">
                    <resource name="submit">
                        <method type="post"><service name="trade.TradeCommonServices.submit#Cancellation"/></method>
                    </resource>
                </id>
            </resource>
        </id>
    </resource>
    <resource name="authorize">
        <method type="post"><service name="trade.AuthorizationServices.authorize#Instrument"/></method>
    </resource>
    <resource name="reject">
        <method type="post"><service name="trade.AuthorizationServices.reject#Instrument"/></method>
    </resource>
    <resource name="approvals">
        <method type="get"><service name="trade.AuthorizationServices.get#PendingApprovals"/></method>
    </resource>
    <resource name="standard-clauses">
        <method type="get"><service name="trade.TradeClauseServices.get#StandardClauses"/></method>
    </resource>

    <resource name="common">
        <resource name="amendments">
            <method type="get"><service name="trade.TradeCommonServices.get#ExternalAmendmentList"/></method>
        </resource>
        <resource name="internal-amendments">
            <method type="get"><service name="trade.TradeCommonServices.get#InternalAmendmentList"/></method>
        </resource>
        <resource name="amendment">
            <id name="amendmentId">
                <method type="get"><service name="trade.TradeCommonServices.get#ExternalAmendment"/></method>
            </id>
        </resource>
        <resource name="internal-amendment">
            <id name="amendmentId">
                <method type="get"><service name="trade.TradeCommonServices.get#InternalAmendment"/></method>
            </id>
        </resource>
        <resource name="presentations">
            <method type="get"><service name="trade.TradeCommonServices.get#PresentationList"/></method>
        </resource>
        <resource name="presentation">
            <id name="presentationId">
                <method type="get"><service name="trade.TradeCommonServices.get#Presentation"/></method>
            </id>
        </resource>
        <resource name="settlements">
            <method type="get"><service name="trade.TradeCommonServices.get#SettlementList"/></method>
        </resource>
        <resource name="settlement">
            <id name="settlementId">
                <method type="get"><service name="trade.TradeCommonServices.get#Settlement"/></method>
            </id>
        </resource>
        <resource name="shipping-guarantees">
            <method type="get"><service name="trade.TradeCommonServices.get#ShippingGuaranteeList"/></method>
        </resource>
        <resource name="shipping-guarantee">
            <id name="guaranteeId">
                <method type="get"><service name="trade.TradeCommonServices.get#ShippingGuarantee"/></method>
            </id>
        </resource>
        <resource name="audit-logs">
            <method type="get"><service name="trade.AdminServices.get#TradeAuditLogs"/></method>
        </resource>
        <resource name="transactions">
            <method type="get"><service name="trade.TradeCommonServices.get#TradeTransactions"/></method>
            <id name="transactionId">
                <method type="get"><service name="trade.TradeCommonServices.get#TradeTransaction"/></method>
                <method type="patch"><service name="trade.TradeCommonServices.update#TradeTransaction"/></method>
            </id>
        </resource>
    </resource>


    <resource name="product-config">
        <method type="post"><service name="trade.AdminServices.update#TradeProductConfig"/></method>
    </resource>

    <resource name="fee-configurations">
        <method type="get"><service name="trade.MasterDataServices.get#FeeConfigurations"/></method>
        <id name="feeConfigurationId">
            <method type="post"><service name="trade.MasterDataServices.update#FeeConfiguration"/></method>
        </id>
    </resource>

    <resource name="product-catalog">
        <method type="get"><service name="trade.MasterDataServices.get#ProductCatalog"/></method>
    </resource>

    <resource name="parties">
        <method type="get"><service name="trade.MasterDataServices.get#Parties"/></method>
        <method type="post"><service name="trade.TradeCommonServices.create#TradeParty"/></method>
        <id name="partyId">
            <method type="get"><service name="trade.TradeCommonServices.get#TradeParty"/></method>
            <method type="post"><service name="trade.TradeCommonServices.update#TradeParty"/></method>
        </id>
    </resource>

    <resource name="authority-profiles">
        <method type="get"><service name="trade.MasterDataServices.get#UserAuthorityProfiles"/></method>
        <id name="userAuthorityId">
            <method type="post"><service name="trade.MasterDataServices.update#UserAuthorityProfile"/></method>
        </id>
    </resource>

    <resource name="exposure-data">
        <method type="get"><service name="trade.LimitServices.get#ExposureData"/></method>
    </resource>

    <resource name="facilities">
        <parameter name="facilityId"/>
        <method type="get"><service name="trade.LimitServices.get#FacilityDetail"/></method>
        <resource name="customer">
            <method type="get"><service name="trade.LimitServices.get#CustomerFacilities"/></method>
        </resource>
    </resource>
    <resource name="instrument">
        <id name="instrumentId">
            <method type="get"><service name="trade.TradeCommonServices.get#Instrument"/></method>
            <resource name="audit-logs">
                <method type="get"><service name="trade.AdminServices.get#TradeAuditLogs"/></method>
            </resource>
            <resource name="transactions">
                <method type="get"><service name="trade.TradeCommonServices.get#InstrumentTransactions"/></method>
            </resource>
            <resource name="swift-messages">
                <method type="get"><service name="trade.SwiftGenerationServices.get#SwiftMessages"/></method>
            </resource>
        </id>
    </resource>
    <resource name="master-data">
        <resource name="load">
            <method type="post"><service name="trade.TradeCommonServices.load#MasterData"/></method>
        </resource>
    </resource>
    <resource name="nostro-reconciliations">
        <method type="get"><service name="trade.TradeAccountingServices.get#NostroReconciliationList"/></method>
        <id name="reconciliationId">
            <resource name="match">
                <method type="put"><service name="trade.TradeAccountingServices.match#NostroReconciliation"/></method>
            </resource>
        </id>
    </resource>
    <resource name="inbox">
        <method type="get"><service name="trade.swift.InboundSwiftServices.get#TradeInboxItems"/></method>
        <id name="inboxItemId">
            <method type="get"><service name="trade.swift.InboundSwiftServices.get#TradeInboxItem"/></method>
            <method type="patch"><service name="update#trade.swift.TradeInboxItem"/></method>
            <resource name="acknowledge"><method type="post"><service name="trade.swift.InboundActionServices.acknowledge#Mt730"/></method></resource>
            <resource name="resolve-amendment"><method type="post"><service name="trade.swift.InboundActionServices.resolve#AmendmentConsent"/></method></resource>
            <resource name="spawn-presentation"><method type="post"><service name="trade.swift.InboundActionServices.spawn#Presentation750"/></method></resource>
            <resource name="process-754"><method type="post"><service name="trade.swift.InboundActionServices.process#Mt754"/></method></resource>
            <resource name="reconcile-742"><method type="post"><service name="trade.swift.InboundActionServices.reconcile#Mt742"/></method></resource>
        </id>
    </resource>
    <resource name="inbound-swift">
        <resource name="ingest">
            <method type="post"><service name="trade.swift.InboundSwiftServices.ingest#SwiftMessage"/></method>
        </resource>
    </resource>
</resource>