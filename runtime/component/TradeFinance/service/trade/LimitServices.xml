<?xml version="1.0" encoding="UTF-8"?>
<!-- ABOUTME: LimitServices handles credit facility earmarking and utilization calculations. -->
<services xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/service-definition-3.0.xsd">

    <service verb="calculate" noun="Earmark" authenticate="false">
        <in-parameters>
            <parameter name="facilityId" required="true"/>
            <parameter name="amount" type="BigDecimal" required="true"/>
        </in-parameters>
        <out-parameters>
            <parameter name="isAllowed" type="Boolean"/>
        </out-parameters>
        <actions>
            <entity-find-one entity-name="trade.CustomerFacility" value-field="facility">
                <field-map field-name="facilityId"/>
            </entity-find-one>
            
            <if condition="!facility"><return error="true" message="Facility ${facilityId} not found"/></if>
            
            <!-- BDD-CMN-ENT-05: Expiry Check -->
            <if condition="facility.facilityExpiryDate &amp;&amp; ec.user.nowTimestamp.after(facility.facilityExpiryDate)">
                <return error="true" message="Credit Facility completely Expired"/>
            </if>

            <set field="available" from="facility.totalApprovedLimit - (facility.utilizedAmount ?: 0)"/>
            <set field="isAllowed" from="amount &lt;= available"/>
            
            <if condition="!isAllowed">
                <message error="true">Insufficient limit. Available: ${available}, Requested: ${amount}</message>
                <return error="true"/>
            </if>
        </actions>
    </service>

    <service verb="update" noun="Utilization" authenticate="false">
        <in-parameters>
            <parameter name="facilityId" required="true"/>
            <parameter name="amountDelta" type="BigDecimal" required="true"/> <!-- Positive to increment, negative to decrement -->
        </in-parameters>
        <actions>
            <script>ec.artifactExecution.disableAuthz()</script>
            <entity-find-one entity-name="trade.CustomerFacility" value-field="facility" for-update="true">
                <field-map field-name="facilityId"/>
            </entity-find-one>
            <if condition="!facility"><return error="true" message="Facility not found"/></if>
            
            <set field="newUtil" from="(facility.utilizedAmount ?: 0) + amountDelta"/>
            <set field="facility.utilizedAmount" from="newUtil"/>
            <entity-update value-field="facility"/>
        </actions>
    </service>
    <service verb="get" noun="ExposureData" authenticate="false">
        <out-parameters>
            <parameter name="totalLimit" type="BigDecimal"/>
            <parameter name="totalExposure" type="BigDecimal"/>
            <parameter name="totalFirm" type="BigDecimal"/>
            <parameter name="totalContingent" type="BigDecimal"/>
            <parameter name="totalReserved" type="BigDecimal"/>
            <parameter name="utilizationPercent" type="BigDecimal"/>
            <parameter name="facilityBreakdown" type="List"><parameter name="facility" type="Map"/></parameter>
        </out-parameters>
        <actions>
            <script>ec.artifactExecution.disableAuthz()</script>
            <entity-find entity-name="trade.CustomerFacility" list="facilityList"/>
            
            <set field="totalLimit" from="0.0" type="BigDecimal"/>
            <set field="totalFirm" from="0.0" type="BigDecimal"/>
            <set field="totalContingent" from="0.0" type="BigDecimal"/>
            <set field="totalReserved" from="0.0" type="BigDecimal"/>
            <set field="facilityBreakdown" from="[]"/>
            
            <iterate list="facilityList" entry="facility">
                <set field="totalLimit" from="totalLimit + (facility.totalApprovedLimit ?: 0)"/>
                
                <entity-find entity-name="trade.TradeInstrument" list="instrumentList">
                    <econdition field-name="customerFacilityId" from="facility.facilityId"/>
                </entity-find>
                
                <set field="fFirm" from="0.0" type="BigDecimal"/>
                <set field="fContingent" from="0.0" type="BigDecimal"/>
                <set field="fReserved" from="0.0" type="BigDecimal"/>
                
                <iterate list="instrumentList" entry="inst">
                    <!-- Get latest transaction status for this instrument -->
                    <entity-find entity-name="trade.TradeTransaction" list="txList">
                        <econdition field-name="instrumentId" from="inst.instrumentId"/>
                        <order-by field-name="-transactionId"/>
                    </entity-find>
                    <set field="txStatus" from="txList ? txList[0].transactionStatusId : null"/>
                    
                    <if condition="txStatus == 'TX_APPROVED'">
                        <set field="fFirm" from="fFirm + (inst.baseEquivalentAmount ?: 0)"/>
                    <else-if condition="txStatus == 'TX_PENDING'">
                        <set field="fContingent" from="fContingent + (inst.baseEquivalentAmount ?: 0)"/>
                    </else-if>
                    <else-if condition="txStatus == 'TX_DRAFT'">
                        <set field="fReserved" from="fReserved + (inst.baseEquivalentAmount ?: 0)"/>
                    </else-if>
                    </if>
                </iterate>
                
                <set field="totalFirm" from="totalFirm + fFirm"/>
                <set field="totalContingent" from="totalContingent + fContingent"/>
                <set field="totalReserved" from="totalReserved + fReserved"/>

                <entity-find-one entity-name="trade.TradeParty" value-field="party">
                    <field-map field-name="partyId" from="facility.ownerPartyId"/>
                </entity-find-one>
                
                <script>
                    facilityBreakdown.add([
                        facilityId: facility.facilityId,
                        facilityName: party?.partyName ?: facility.facilityId,
                        limit: facility.totalApprovedLimit,
                        firm: fFirm,
                        contingent: fContingent,
                        reserved: fReserved,
                        available: (facility.totalApprovedLimit ?: 0) - (fFirm + fContingent + fReserved)
                    ])
                </script>
            </iterate>
            
            <set field="totalExposure" from="totalFirm + totalContingent + totalReserved" type="BigDecimal"/>
            <set field="utilizationPercent" from="totalLimit > 0 ? (totalExposure / totalLimit) * 100 : 0"/>
        </actions>
    </service>

    <service verb="get" noun="FacilityDetail" authenticate="false">
        <in-parameters>
            <parameter name="facilityId" required="true"/>
        </in-parameters>
        <out-parameters>
            <parameter name="facility" type="Map"/>
            <parameter name="transactions" type="List"><parameter name="tran" type="Map"/></parameter>
        </out-parameters>
        <actions>
            <script>ec.artifactExecution.disableAuthz()</script>
            <entity-find-one entity-name="trade.CustomerFacility" value-field="facilityField">
                <field-map field-name="facilityId"/>
            </entity-find-one>
            
            <if condition="!facilityField"><return error="true" message="Facility ${facilityId} not found"/></if>
            
            <entity-find entity-name="trade.TradeInstrument" list="instrumentList">
                <econdition field-name="customerFacilityId" from="facilityId"/>
                <order-by field-name="-issueDate"/>
            </entity-find>
            
            <set field="fFirm" from="0.0" type="BigDecimal"/>
            <set field="fContingent" from="0.0" type="BigDecimal"/>
            <set field="fReserved" from="0.0" type="BigDecimal"/>
            <set field="transactions" from="[]"/>
            
            <iterate list="instrumentList" entry="inst">
                <!-- Get latest transaction status -->
                <entity-find entity-name="trade.TradeTransaction" list="txList">
                    <econdition field-name="instrumentId" from="inst.instrumentId"/>
                    <order-by field-name="-transactionId"/>
                </entity-find>
                <set field="tx" from="txList ? txList[0] : null"/>
                <set field="txStatus" from="tx?.transactionStatusId"/>
                
                <if condition="txStatus == 'TX_APPROVED'">
                    <set field="fFirm" from="fFirm + (inst.baseEquivalentAmount ?: 0)"/>
                <else-if condition="txStatus == 'TX_PENDING'">
                    <set field="fContingent" from="fContingent + (inst.baseEquivalentAmount ?: 0)"/>
                </else-if>
                <else-if condition="txStatus == 'TX_DRAFT'">
                    <set field="fReserved" from="fReserved + (inst.baseEquivalentAmount ?: 0)"/>
                </else-if>
                </if>
                
                <script>
                    transactions.add([
                        instrumentId: inst.instrumentId,
                        transactionRef: inst.transactionRef,
                        businessStateId: inst.businessStateId,
                        transactionStatusId: txStatus,
                        effectiveOutstandingAmount: inst.baseEquivalentAmount,
                        transactionDate: tx?.transactionDate ?: inst.issueDate
                    ])
                </script>
            </iterate>
            
            <entity-find-one entity-name="trade.TradeParty" value-field="party">
                <field-map field-name="partyId" from="facilityField.ownerPartyId"/>
            </entity-find-one>
            
            <set field="facility" from="[
                facilityId: facilityField.facilityId,
                facilityName: party?.partyName ?: facilityField.facilityId,
                limit: facilityField.totalApprovedLimit,
                firm: fFirm,
                contingent: fContingent,
                reserved: fReserved,
                available: (facilityField.totalApprovedLimit ?: 0) - (fFirm + fContingent + fReserved)
            ]"/>
        </actions>
    </service>
    <service verb="reverse" noun="Limit" authenticate="false">
        <in-parameters><parameter name="instrumentId" required="true"/></in-parameters>
        <actions>
            <script>ec.artifactExecution.disableAuthz()</script>
            <entity-find-one entity-name="trade.importlc.ImportLetterOfCredit" value-field="lc"/>
            <if condition="!lc"><return/></if>
            <entity-find-one entity-name="trade.TradeInstrument" value-field="instrument"/>
            
            <if condition="instrument.customerFacilityId">
                <!-- Decrement utilization by remaining outstanding amount -->
                <script>
                    def amount = lc.effectiveOutstandingAmount ?: 0.0
                    ec.service.sync().name("trade.LimitServices.update#Utilization")
                        .parameters([facilityId: instrument.customerFacilityId, amountDelta: -amount]).call()
                </script>
            </if>
        </actions>
    </service>
    <service verb="get" noun="CustomerFacilities" authenticate="false">
        <in-parameters><parameter name="partyId" required="true"/></in-parameters>
        <out-parameters>
            <parameter name="facilityList" type="List"><parameter name="facility" type="Map"/></parameter>
        </out-parameters>
        <actions>
            <script>ec.artifactExecution.disableAuthz()</script>
            <log message="Fetching facilities for partyId: ${partyId}"/>
            <entity-find entity-name="trade.CustomerFacility" list="rawList">
                <econdition field-name="ownerPartyId" from="partyId"/>
            </entity-find>
            <log message="Found ${rawList.size()} facilities for partyId: ${partyId}"/>
            <script>
                facilityList = rawList.collect { f ->
                    [
                        facilityId: f.facilityId,
                        description: f.description,
                        limitAmount: f.totalApprovedLimit,
                        utilizedAmount: f.utilizedAmount,
                        currency: f.currencyUomId
                    ]
                }
            </script>
            <script>ec.artifactExecution.enableAuthz()</script>
        </actions>
    </service>
</services>
