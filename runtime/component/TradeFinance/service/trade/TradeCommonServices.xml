<?xml version="1.0" encoding="UTF-8"?>
<services xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/service-definition-3.0.xsd">

    <!-- ABOUTME: TradeCommonServices provides utility services for trade operations, like sequence generation. -->

    <service verb="get" noun="NextNumber" authenticate="false">
        <in-parameters>
            <parameter name="sequenceId" required="true"/>
            <parameter name="instrumentType" required="true"/> <!-- e.g., IMP, EXP -->
        </in-parameters>
        <out-parameters>
            <parameter name="nextNumberFormatted" required="true"/>
        </out-parameters>
        <actions>
            <entity-find-one entity-name="trade.common.NumberSequence" value-field="seq" for-update="true"/>
            <if condition="seq == null">
                <return error="true" message="NumberSequence ${sequenceId} not found"/>
            </if>
            
            <set field="newNumber" from="seq.lastNumber + 1"/>
            <set field="seq.lastNumber" from="newNumber"/>
            <entity-update value-field="seq"/>
            
            <set field="yearShort" from="ec.user.nowTimestamp.toLocalDateTime().getYear().toString().substring(2)"/>
            <set field="numberFormatted" from="newNumber.toString().padLeft(4, '0')"/>
            
            <set field="nextNumberFormatted" from="'TF-' + instrumentType + '-' + yearShort + '-' + numberFormatted"/>
        </actions>
    </service>
</services>
