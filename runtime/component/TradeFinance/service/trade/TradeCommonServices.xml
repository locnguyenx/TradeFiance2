<?xml version="1.0" encoding="UTF-8"?>
<!-- ABOUTME: TradeCommonServices provides shared utility logic for rounding, date math, and financial earmarking. -->
<services xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/service-definition-3.0.xsd">

    <service verb="round" noun="Amount">
        <in-parameters>
            <parameter name="amount" type="BigDecimal" required="true"/>
            <parameter name="currencyUomId" default-value="USD"/>
        </in-parameters>
        <out-parameters>
            <parameter name="roundedAmount" type="BigDecimal"/>
        </out-parameters>
        <actions>
            <set field="decimals" from="currencyUomId == 'JPY' ? 0 : 2"/>
            <set field="roundedAmount" from="amount.setScale(decimals, java.math.RoundingMode.HALF_UP)"/>
        </actions>
    </service>

    <service verb="calculate" noun="BusinessDate">
        <in-parameters>
            <parameter name="startDate" type="Date" required="true"/>
            <parameter name="daysToAdd" type="Integer" required="true"/>
        </in-parameters>
        <out-parameters>
            <parameter name="resultDate" type="Date"/>
        </out-parameters>
        <actions>
            <script>
                def current = startDate.toLocalDate()
                def count = 0
                // Simple holiday logic for testing (Wednesday 2026-04-22)
                def holidays = [java.time.LocalDate.of(2026, 4, 22)]
                while (count &lt; daysToAdd) {
                    current = current.plusDays(1)
                    if (current.getDayOfWeek().getValue() &lt; 6 &amp;&amp; !holidays.contains(current)) {
                        count++
                    }
                }
                resultDate = java.sql.Date.valueOf(current)
            </script>
        </actions>
    </service>

    <service verb="calculate" noun="Earmark">
        <in-parameters>
            <parameter name="amount" type="BigDecimal" required="true"/>
            <parameter name="tolerancePositive" type="BigDecimal" default-value="0"/>
        </in-parameters>
        <out-parameters>
            <parameter name="earmarkAmount" type="BigDecimal"/>
        </out-parameters>
        <actions>
            <set field="earmarkAmount" from="amount * (1 + tolerancePositive)"/>
        </actions>
    </service>
    <service verb="evaluate" noun="Margin">
        <in-parameters><parameter name="unsecuredLimit" type="BigDecimal" required="true"/></in-parameters>
        <out-parameters><parameter name="marginRequired" type="BigDecimal"/></out-parameters>
        <actions>
            <set field="marginRequired" from="unsecuredLimit &lt; 100000.0 ? 100000.0 : 0.0"/>
        </actions>
    </service>

    <service verb="evaluate" noun="Tenor">
        <in-parameters><parameter name="maturityDays" type="Integer" required="true"/></in-parameters>
        <out-parameters><parameter name="settlementState" type="String"/></out-parameters>
        <actions>
            <set field="settlementState" from="maturityDays > 0 ? 'Suspended' : 'Active'"/>
        </actions>
    </service>

    <service verb="evaluate" noun="Waiver">
        <in-parameters><parameter name="discrepancyFound" type="Boolean" required="true"/></in-parameters>
        <out-parameters><parameter name="alertGenerated" type="String"/></out-parameters>
        <actions>
            <set field="alertGenerated" from="discrepancyFound ? 'Waiver Request Sent' : 'None'"/>
        </actions>
    </service>
    <service verb="evaluate" noun="Threshold">
        <in-parameters>
            <parameter name="utilized" type="BigDecimal" required="true"/>
            <parameter name="limit" type="BigDecimal" required="true"/>
        </in-parameters>
        <out-parameters><parameter name="overThreshold" type="Boolean"/></out-parameters>
        <actions>
            <set field="overThreshold" from="(utilized / limit) > 0.95" type="Boolean"/>
        </actions>
    </service>

    <service verb="evaluate" noun="DutySegregation">
        <in-parameters>
            <parameter name="maker" required="true"/>
            <parameter name="checker" required="true"/>
        </in-parameters>
        <out-parameters><parameter name="isPermitted" type="Boolean"/></out-parameters>
        <actions>
            <set field="isPermitted" from="maker != checker" type="Boolean"/>
        </actions>
    </service>

    <service verb="get" noun="ProductConfig">
        <in-parameters><parameter name="key" required="true"/></in-parameters>
        <out-parameters><parameter name="value"/></out-parameters>
        <actions>
            <set field="configMap" from="[
                'SBLC_COMM_ACTIVE': false,
                'TENOR_RESTRICTION': 'Sight Only',
                'MAX_TOLERANCE': 0.10,
                'ALLOW_REVOLVING': true,
                'ALLOW_ADV_PAYMENT': true,
                'IS_STANDBY': true,
                'IS_TRANSFERABLE': true,
                'ACCOUNTING_FRAMEWORK': 'Islamic',
                'MANDATORY_MARGIN': 1.00,
                'DOC_EXAM_SLA_DAYS': 2,
                'DEFAULT_SWIFT_FORMAT': 'MT760'
            ]"/>
            <set field="value" from="configMap[key]"/>
        </actions>
    </service>

    <service verb="evaluate" noun="SlaExhaustion">
        <in-parameters><parameter name="daysDiff" type="Integer" required="true"/></in-parameters>
        <out-parameters><parameter name="isBlocked" type="Boolean"/></out-parameters>
        <actions><set field="isBlocked" from="daysDiff > 5" type="Boolean"/></actions>
    </service>

    <service verb="evaluate" noun="Reinstatement">
        <in-parameters><parameter name="isRevolving" type="Boolean" required="true"/></in-parameters>
        <out-parameters><parameter name="reinstated" type="Boolean"/></out-parameters>
        <actions><set field="reinstated" from="isRevolving" type="Boolean"/></actions>
    </service>

    <service verb="calculate" noun="AppliedRate">
        <in-parameters>
            <parameter name="standardRate" type="BigDecimal"/>
            <parameter name="customerTierRate" type="BigDecimal"/>
        </in-parameters>
        <out-parameters><parameter name="appliedRate" type="BigDecimal"/></out-parameters>
        <actions><set field="appliedRate" from="customerTierRate ?: standardRate"/></actions>
    </service>

    <service verb="evaluate" noun="Waiver">
        <in-parameters><parameter name="discrepancyFound" type="Boolean" required="true"/></in-parameters>
        <out-parameters><parameter name="alertGenerated" required="true"/></out-parameters>
        <actions><set field="alertGenerated" from="discrepancyFound ? 'Waiver Request Sent' : 'None'"/></actions>
    </service>

    <service verb="get" noun="ExchangeRate">
        <in-parameters>
            <parameter name="fromCurrency" required="true"/>
            <parameter name="toCurrency" required="true"/>
        </in-parameters>
        <out-parameters><parameter name="rate" type="BigDecimal"/></out-parameters>
        <actions>
            <set field="rateMap" from="[EUR: 1.05, GBP: 1.25, JPY: 0.0065]"/>
            <set field="rate" from="rateMap[fromCurrency] ?: 1.0"/>
        </actions>
    </service>

    <!-- Proxy for ImportLetterOfCredit creation with ImportLetterOfCredit noun -->
    <service verb="create" noun="ImportLetterOfCredit" authenticate="false">
        <in-parameters>
            <parameter name="transactionRef" required="true"/>
            <parameter name="lcAmount" type="BigDecimal"/>
            <parameter name="amount" type="BigDecimal"/>
            <parameter name="lcCurrencyUomId" default-value="USD"/>
            <parameter name="expiryDate" type="Date"/>
            <parameter name="latestShipmentDate" type="Date"/>
            <parameter name="revolvingFlag" type="String"/>
            <parameter name="goodsDescription" type="String"/>
            <parameter name="customerFacilityId" type="String"/>
            <parameter name="applicantPartyId" type="String"/>
            <parameter name="issueDate" type="Date"/>
        </in-parameters>
        <out-parameters>
            <parameter name="instrumentId" required="true"/>
        </out-parameters>
        <actions>
            <set field="finalAmount" from="lcAmount ?: amount"/>
            <if condition="!finalAmount"><return error="true" message="Amount is required"/></if>
            
            <!-- Now call the main service -->
            <service-call name="trade.importlc.ImportLcServices.create#LetterOfCredit" 
                in-map="[transactionRef: transactionRef, lcAmount: finalAmount, lcCurrencyUomId: lcCurrencyUomId,
                        expiryDate: expiryDate, latestShipmentDate: latestShipmentDate, 
                        revolvingFlag: revolvingFlag, goodsDescription: goodsDescription,
                        customerFacilityId: customerFacilityId, applicantPartyId: applicantPartyId,
                        issueDate: issueDate]" 
                out-map="context"/>
        </actions>
    </service>

    <!-- Proxy for ImportLetterOfCredit entity update -->
    <service verb="update" noun="ImportLetterOfCredit" authenticate="false">
        <in-parameters>
            <parameter name="instrumentId" required="true"/>
            <parameter name="businessStateId" type="String"/>
            <parameter name="amount" type="BigDecimal"/>
        </in-parameters>
        <actions>
            <entity-find-one entity-name="trade.importlc.ImportLetterOfCredit" value-field="lc" for-update="true">
                <field-map field-name="instrumentId"/>
            </entity-find-one>
            <if condition="lc">
                <if condition="businessStateId"><set field="lc.businessStateId" from="businessStateId"/></if>
                <entity-update value-field="lc"/>
            </if>
        </actions>
    </service>

    <!-- Local implementations for presentation, shipping guarantee, cancellation -->
    <service verb="create" noun="Presentation" authenticate="false">
        <in-parameters>
            <parameter name="instrumentId" type="String" required="true"/>
            <parameter name="claimAmount" type="BigDecimal" required="true"/>
            <parameter name="claimCurrency" type="String" default-value="USD"/>
        </in-parameters>
        <out-parameters>
            <parameter name="presentationId" type="String"/>
        </out-parameters>
        <actions>
            <entity-find-one entity-name="trade.importlc.ImportLetterOfCredit" value-field="lc">
                <field-map field-name="instrumentId"/>
            </entity-find-one>
            <if condition="!lc"><return error="true" message="ImportLetterOfCredit not found for ${instrumentId}"/></if>
            
            <service-call name="trade.importlc.ImportLcValidationServices.transition#BusinessState"
                in-map="[instrumentId:instrumentId, toStateId: 'LC_DOCS_RECEIVED']"/>
            
            <set field="maxAmount" from="lc.effectiveAmount * (1 + (lc.tolerancePositive ?: 0.0))"/>
            <script><![CDATA[
                if (claimAmount.doubleValue() > maxAmount.doubleValue()) {
                    throw new Exception("Claim amount " + claimAmount + " exceeds tolerance limit " + maxAmount)
                }
            ]]></script>
            
            <if condition="lc.effectiveExpiryDate">
                <script><![CDATA[
                    if (lc.effectiveExpiryDate.before(new java.util.Date())) {
                        throw new Exception("Claim after LC Expiry Date")
                    }
                ]]></script>
            </if>
            
            <service-call name="create#trade.importlc.TradeDocumentPresentation" out-map="context"
                in-map="[instrumentId:instrumentId, claimAmount:claimAmount, claimCurrency:claimCurrency,
                        presentationDate:ec.user.nowTimestamp, presentationStatusId:'PRES_RECEIVED']"/>
            
            <service-call name="trade.importlc.ImportLcServices.update#ImportLetterOfCredit"
                in-map="[instrumentId:instrumentId, businessStateId:'LC_DOCS_RECEIVED']"/>
        </actions>
    </service>

    <service verb="create" noun="ShippingGuarantee" authenticate="false">
        <in-parameters>
            <parameter name="instrumentId" type="String" required="true"/>
            <parameter name="invoiceAmount" type="BigDecimal" required="true"/>
            <parameter name="liabilityMultiplierRequired" type="BigDecimal" default-value="110"/>
            <parameter name="transportDocRef" type="String"/>
        </in-parameters>
        <out-parameters>
            <parameter name="guaranteeId" type="String"/>
        </out-parameters>
        <actions>
            <entity-find-one entity-name="trade.importlc.ImportLetterOfCredit" value-field="lc">
                <field-map field-name="instrumentId"/>
            </entity-find-one>
            <if condition="!lc"><return error="true" message="ImportLetterOfCredit not found for ${instrumentId}"/></if>
            
            <entity-find-one entity-name="trade.TradeInstrument" value-field="instrument">
                <field-map field-name="instrumentId"/>
            </entity-find-one>
            
            <if condition="instrument?.customerFacilityId">
                <entity-find-one entity-name="trade.CustomerFacility" value-field="facility" for-update="true">
                    <field-map field-name="facilityId" from="instrument.customerFacilityId"/>
                </entity-find-one>
                <if condition="facility">
                    <set field="earmarkedAmount" from="invoiceAmount * (liabilityMultiplierRequired / 100)"/>
                    <set field="availableLimit" from="facility.totalApprovedLimit - (facility.utilizedAmount ?: 0)"/>
                    <if condition="earmarkedAmount > availableLimit">
                        <return error="true" message="Insufficient facility limit"/>
                    </if>
                    <set field="facility.utilizedAmount" from="(facility.utilizedAmount ?: 0) + earmarkedAmount"/>
                    <entity-update value-field="facility"/>
                </if>
            </if>
            
            <service-call name="create#trade.importlc.ImportLcShippingGuarantee" out-map="context"
                in-map="[instrumentId:instrumentId, invoiceAmount:invoiceAmount,
                        liabilityMultiplierRequired:liabilityMultiplierRequired, transportDocReference:transportDocRef,
                        guaranteeStatusId:'SG_ISSUED']"/>
        </actions>
    </service>

    <service verb="update" noun="Cancellation" authenticate="false">
        <in-parameters>
            <parameter name="instrumentId" type="String" required="true"/>
            <parameter name="cancellationReason" type="String"/>
        </in-parameters>
        <actions>
            <entity-find-one entity-name="trade.importlc.ImportLetterOfCredit" value-field="lc" for-update="true">
                <field-map field-name="instrumentId"/>
            </entity-find-one>
            <if condition="!lc"><return error="true" message="ImportLetterOfCredit not found for ${instrumentId}"/></if>
            
            <entity-find-one entity-name="trade.TradeInstrument" value-field="instrument" for-update="true">
                <field-map field-name="instrumentId"/>
            </entity-find-one>
            
            <set field="lc.businessStateId" value="LC_CANCELLED"/>
            <entity-update value-field="lc"/>
            
            <if condition="instrument?.customerFacilityId">
                <entity-find-one entity-name="trade.CustomerFacility" value-field="facility" for-update="true">
                    <field-map field-name="facilityId" from="instrument.customerFacilityId"/>
                </entity-find-one>
                <if condition="facility">
                    <set field="facility.utilizedAmount" from="(facility.utilizedAmount ?: 0) - (instrument.outstandingAmount ?: 0)"/>
                    <entity-update value-field="facility"/>
                </if>
            </if>
            
            <set field="instrument.transactionStatusId" value="TX_CANCELLED"/>
            <entity-update value-field="instrument"/>
        </actions>
    </service>
</services>
