<?xml version="1.0" encoding="UTF-8"?>
<!-- ABOUTME: ImportLcValidationServices enforces SWIFT and business rule compliance for LC operations. -->
<services xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/service-definition-3.0.xsd">

    <service verb="evaluate" noun="Drawing">
        <in-parameters>
            <parameter name="instrumentId" required="true"/>
            <parameter name="claimAmount" type="BigDecimal" required="true"/>
        </in-parameters>
        <actions>
            <entity-find-one entity-name="moqui.trade.importlc.ImportLetterOfCredit" value-field="lc">
                <field-map field-name="instrumentId"/>
            </entity-find-one>
            <entity-find-one entity-name="moqui.trade.instrument.TradeInstrument" value-field="instrument">
                <field-map field-name="instrumentId"/>
            </entity-find-one>
            
            <if condition="!lc"><return error="true" message="LC not found"/></if>
            
            <set field="maxAllowed" from="instrument.baseEquivalentAmount * (1 + (lc.tolerancePositive ?: 0))"/>
            <if condition="claimAmount \u003e maxAllowed">
                <return error="true" message="Claim amount ${claimAmount} exceeds tolerance limit ${maxAllowed}"/>
            </if>
        </actions>
    </service>
</services>
