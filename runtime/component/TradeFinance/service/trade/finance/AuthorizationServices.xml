<?xml version="1.0" encoding="UTF-8"?>
<!-- ABOUTME: AuthorizationServices implements the Maker/Checker risk matrix and authority level evaluation. -->
<services xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/service-definition-3.0.xsd">

    <service verb="evaluate" noun="MakerCheckerMatrix">
        <in-parameters>
            <parameter name="instrumentId" required="true"/>
            <parameter name="userId" required="true"/>
        </in-parameters>
        <out-parameters>
            <parameter name="isAuthorized" type="Boolean"/>
        </out-parameters>
        <actions>
            <entity-find-one entity-name="moqui.trade.instrument.TradeInstrument" value-field="instrument">
                <field-map field-name="instrumentId"/>
            </entity-find-one>
            
            <!-- Prohibit same user from Maker and Checker actions -->
            <entity-find-one entity-name="moqui.trade.instrument.TradeTransactionAudit" value-field="makerAudit">
                <field-map field-name="instrumentId" from="instrumentId"/>
                <field-map field-name="actionEnumId" value="MAKER_COMMIT"/>
            </entity-find-one>
            
            <set field="isAuthorized" from="makerAudit?.userId != userId"/>
        </actions>
    </service>
</services>
