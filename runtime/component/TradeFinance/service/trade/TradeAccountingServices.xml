<?xml version="1.0" encoding="UTF-8"?>
<!-- ABOUTME: TradeAccountingServices manages financial entries and fee calculations. -->
<services xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/service-definition-3.0.xsd">

    <service verb="post" noun="TradeEntry" authenticate="false">
        <in-parameters>
            <parameter name="instrumentId" required="true"/>
            <parameter name="amount" type="BigDecimal" required="true"/>
            <parameter name="currencyUomId" default-value="USD"/>
            <parameter name="entryType" default-value="ISSUANCE"/>
        </in-parameters>
        <actions>
            <entity-find-one entity-name="trade.TradeInstrument" value-field="instrument"/>
            <script><![CDATA[
                try {
                    def debitConfig = ec.entity.find("trade.common.TradeConfig").condition("configKey", "GL_TRADE_DEBIT").one()
                    def creditConfig = ec.entity.find("trade.common.TradeConfig").condition("configKey", "GL_TRADE_CREDIT").one()
                    def debitGl = debitConfig?.configValue ?: '111000'
                    def creditGl = creditConfig?.configValue ?: '411000'

                    def acctgTransId = ec.entity.makeValue("mantle.ledger.transaction.AcctgTrans", [
                        acctgTransTypeEnumId: 'ATT_FINANCIAL_ENTRY',
                        lastUpdatedStamp: ec.user.nowTimestamp,
                        isSettled: 'Y'
                    ]).setSequencedIdPrimary().create().acctgTransId
                    
                    ec.entity.makeValue("mantle.ledger.transaction.AcctgTransEntry", [acctgTransId: acctgTransId, acctgTransEntrySeqId: '01', glAccountId: debitGl, amount: amount, debitCreditFlag: 'D']).create()
                    ec.entity.makeValue("mantle.ledger.transaction.AcctgTransEntry", [acctgTransId: acctgTransId, acctgTransEntrySeqId: '02', glAccountId: creditGl, amount: amount, debitCreditFlag: 'C']).create()
                } catch (Exception e) { ec.logger.error("Accounting error: " + e.message) }
            ]]></script>
        </actions>
    </service>

    <service verb="calculate" noun="Fees" authenticate="false">
        <in-parameters>
            <parameter name="baseAmount" type="BigDecimal" required="true"/>
            <parameter name="feeEventEnumId" default-value="ISSUANCE_FEE"/>
            <parameter name="partyId"/>
            <parameter name="minCharge" type="BigDecimal"/>
            <parameter name="maxCharge" type="BigDecimal"/>
        </in-parameters>
        <out-parameters>
            <parameter name="totalFee" type="BigDecimal"/>
        </out-parameters>
        <actions>
            <entity-find entity-name="trade.FeeConfiguration" list="customerConfigs" limit="1">
                <econdition field-name="feeEventEnumId" from="feeEventEnumId ?: 'ISSUANCE_FEE'"/>
                <econdition field-name="partyId" from="partyId"/>
                <econdition field-name="statusId" value="FEE_ACTIVE"/>
                <order-by field-name="-effectiveDate"/>
            </entity-find>
            <entity-find entity-name="trade.FeeConfiguration" list="standardConfigs" limit="1">
                <econdition field-name="feeEventEnumId" from="feeEventEnumId ?: 'ISSUANCE_FEE'"/>
                <econdition field-name="partyId" value=""/>
                <econdition field-name="statusId" value="FEE_ACTIVE"/>
                <order-by field-name="-effectiveDate"/>
            </entity-find>

            <script><![CDATA[
                def feeConfig = customerConfigs ? customerConfigs[0] : (standardConfigs ? standardConfigs[0] : null)
                BigDecimal result = 0.0
                if (feeConfig == null) {
                    result = baseAmount * 0.0025
                    if (minCharge && result < minCharge) result = minCharge
                    if (maxCharge && result > maxCharge) result = maxCharge
                } else {
                    def base = feeConfig.baseValue ?: feeConfig.ratePercent ?: 0.0
                    if (feeConfig.calculationTypeEnumId == 'PERCENTAGE') {
                        result = baseAmount * base
                    } else {
                        result = base
                    }
                    def minFloor = minCharge ?: feeConfig.minFloorAmount
                    def maxCeiling = maxCharge ?: feeConfig.maxCeilingAmount
                    if (minFloor && result < minFloor) result = minFloor
                    if (maxCeiling && result > maxCeiling) result = maxCeiling
                }
                context.totalFee = result
            ]]></script>
        </actions>
    </service>

    <service verb="create" noun="ImportLcSettlement" authenticate="false">
        <in-parameters>
            <parameter name="presentationId" required="true"/>
            <parameter name="instrumentId" required="true"/>
            <parameter name="principalAmount" type="BigDecimal" required="true"/>
            <parameter name="settlementTypeEnumId" required="true"/>
            <parameter name="transactionStatusId" default="TX_DRAFT"/>
            <auto-parameters entity-name="trade.importlc.ImportLcSettlement" include="nonpk"/>
        </in-parameters>
        <out-parameters>
            <parameter name="settlementId" required="true"/>
            <parameter name="transactionId" required="true"/>
        </out-parameters>
        <actions>
            <script>ec.artifactExecution.disableAuthz()</script>
            <entity-find-one entity-name="trade.importlc.ImportLetterOfCredit" value-field="lc">
                <field-map field-name="instrumentId"/>
            </entity-find-one>
            <if condition="!lc || !(lc.businessStateId in ['LC_ISSUED', 'LC_AMENDED', 'LC_DOC_RECEIVED', 'LC_ACCEPTED'])">
                <return error="true" message="Settlements can only be created for Issued instruments (Current State: ${lc?.businessStateId ?: 'UNKNOWN'})"/>
            </if>

            <entity-make-value entity-name="trade.importlc.ImportLcSettlement" value-field="settlement"/>
            <entity-set value-field="settlement" map="context"/>
            <entity-sequenced-id-primary value-field="settlement"/>
            <entity-create value-field="settlement"/>
            <set field="settlementId" from="settlement.settlementId"/>

            <service-call name="create#trade.TradeTransaction" out-map="txOut"
                in-map="[
                    instrumentId: instrumentId,
                    transactionTypeEnumId: 'IMP_SETTLEMENT',
                    transactionStatusId: transactionStatusId,
                    transactionDate: ec.user.nowTimestamp,
                    makerUserId: ec.user.userId,
                    makerTimestamp: ec.user.nowTimestamp,
                    priorityEnumId: priorityEnumId ?: 'PRIO_NORMAL',
                    versionNumber: 1,
                    relatedRecordId: settlementId,
                    relatedRecordType: 'SETTLEMENT'
                ]"/>
            <set field="transactionId" from="txOut.transactionId"/>
        </actions>
    </service>

    <service verb="update" noun="ImportLcSettlement" authenticate="false">
        <in-parameters>
            <parameter name="settlementId" required="true"/>
            <auto-parameters entity-name="trade.importlc.ImportLcSettlement" include="nonpk"/>
        </in-parameters>
        <actions>
            <entity-find-one entity-name="trade.importlc.ImportLcSettlement" value-field="settlement" for-update="true"/>
            <if condition="!settlement"><return error="true" message="Settlement ${settlementId} not found"/></if>
            <entity-set value-field="settlement" include="nonpk" map="context"/>
            <entity-update value-field="settlement"/>
        </actions>
    </service>

    <service verb="submit" noun="ImportLcSettlement" authenticate="false">
        <in-parameters>
            <parameter name="settlementId" required="true"/>
            <auto-parameters entity-name="trade.importlc.ImportLcSettlement" include="nonpk"/>
        </in-parameters>
        <actions>
            <!-- Update payload -->
            <service-call name="trade.TradeAccountingServices.update#ImportLcSettlement" in-map="context"/>
            
            <!-- Transition Transaction to PENDING -->
            <entity-find entity-name="trade.TradeTransaction" list="txList">
                <econdition field-name="relatedRecordId" from="settlementId"/>
                <econdition field-name="transactionTypeEnumId" value="IMP_SETTLEMENT"/>
                <econdition field-name="transactionStatusId" value="TX_DRAFT"/>
            </entity-find>
            <if condition="txList">
                <service-call name="trade.TradeCommonServices.update#TradeTransaction" 
                    in-map="[transactionId: txList[0].transactionId, transactionStatusId: 'TX_PENDING']"/>
            </if>
            
            <!-- NOTE: Actual LC balance update and state change moved to Authorization flow -->
        </actions>
    </service>
    <service verb="get" noun="NostroReconciliationList" authenticate="false">
        <out-parameters>
            <parameter name="reconciliationList" type="List"><parameter name="reconciliation" type="Map"/></parameter>
        </out-parameters>
        <actions>
            <entity-find entity-name="trade.importlc.NostroReconciliation" list="reconciliationList">
                <order-by field-name="-reconciliationId"/>
            </entity-find>
        </actions>
    </service>

    <service verb="match" noun="NostroReconciliation" authenticate="false">
        <in-parameters>
            <parameter name="reconciliationId" required="true"/>
            <parameter name="nostroDebitDate" type="Date" required="true"/>
            <parameter name="nostroDebitAmount" type="BigDecimal" required="true"/>
            <parameter name="nostroStatementRef" required="true"/>
            <parameter name="matchStatusEnumId" default-value="RECON_MATCHED"/>
            <parameter name="remarks"/>
        </in-parameters>
        <actions>
            <entity-find-one entity-name="trade.importlc.NostroReconciliation" value-field="reconciliation" for-update="true"/>
            <if condition="!reconciliation"><return error="true" message="Nostro Reconciliation record ${reconciliationId} not found"/></if>
            
            <entity-set value-field="reconciliation" include="nonpk" map="context"/>
            <set field="reconciliation.matchedByUserId" from="ec.user.userId"/>
            <set field="reconciliation.matchedDate" from="ec.user.nowTimestamp"/>
            <entity-update value-field="reconciliation"/>
        </actions>
    </service>
</services>
