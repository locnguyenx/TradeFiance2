    </service>

    <service verb="generate" noun="Mt752">
        <in-parameters><parameter name="presentationId" required="true"/></in-parameters>
        <out-parameters><parameter name="swiftMessageId" type="id"/></out-parameters>
        <actions>
            <entity-find-one entity-name="trade.importlc.TradeDocumentPresentation" value-field="presentation"/>
            <set field="instrumentId" from="presentation.instrumentId"/>
            <set field="msgText" value="{1:F01...}{2:I752...}{4:\n:20:${presentation.presentingBankRef}\n:21:${presentation.instrumentId}\n:30:${ec.user.nowTimestamp.format('yyMMdd')}\n:32B:USD${presentation.claimAmount}\n-}"/>
            <service-call name="create#trade.importlc.SwiftMessage" in-map="[instrumentId:instrumentId, messageType:'MT752', messageContent:msgText]" out-map="createOut"/>
            <set field="swiftMessageId" from="createOut.swiftMessageId"/>
        </actions>
    </service>
</services>
