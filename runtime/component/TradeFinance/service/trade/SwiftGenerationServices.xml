            <set field="msgText" value="{1:F01...}{2:I202...}{4:\n:20:${settlement.settlementId}\n:21:NONREF\n:32A:${ec.user.nowTimestamp.format('yyMMdd')}USD${settlement.principalAmount}\n-}"/>
            <service-call name="create#trade.importlc.SwiftMessage" in-map="[instrumentId:settlement.instrumentId, messageType:'MT202', messageContent:msgText]" out-map="createOut"/>
            <set field="swiftMessageId" from="createOut.swiftMessageId"/>
        </actions>
    </service>

