<?xml version="1.0" encoding="UTF-8"?>
<!-- ABOUTME: AuthorizationServices implements the Maker/Checker risk matrix and authority level evaluation. -->
<services xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/service-definition-3.0.xsd">

    <service verb="evaluate" noun="MakerCheckerMatrix" authenticate="false">
        <in-parameters>
            <parameter name="instrumentId"/>
            <parameter name="transactionId"/>
            <parameter name="userId" default="ec.user.userId ?: 'EXOR_SERVICE_USER'"/>
            <parameter name="skipFourEyes" type="Boolean" default="false"/>
        </in-parameters>
        <out-parameters>
            <parameter name="isAuthorized" type="Boolean"/>
            <parameter name="authorityTierEnumId"/>
            <parameter name="evaluationAmount" type="BigDecimal"/>
        </out-parameters>
        <actions>
            <script>ec.artifactExecution.disableAuthz()</script>
            <if condition="skipFourEyes"><set field="isAuthorized" value="true" type="Boolean"/><return/></if>
            
            <!-- Resolve instrument from transaction or direct -->
            <set field="localInstrumentId" from="instrumentId"/>
            <if condition="transactionId">
                <entity-find-one entity-name="trade.TradeTransaction" value-field="tx">
                    <field-map field-name="transactionId"/>
                </entity-find-one>
                <if condition="tx">
                    <set field="localInstrumentId" from="tx.instrumentId"/>
                </if>
            </if>
            
            <entity-find-one entity-name="trade.TradeInstrument" value-field="instrument">
                <field-map field-name="instrumentId" from="localInstrumentId"/>
            </entity-find-one>
            <if condition="!instrument">
                <return error="true" message="Instrument not found"/>
            </if>

            <!-- Get evaluation amount -->
            <set field="evaluationAmount" from="instrument.amount ?: 0"/>
            <if condition="instrument.instrumentTypeEnumId == 'IMPORT_LC'">
                <entity-find-one entity-name="trade.importlc.ImportLetterOfCredit" value-field="lc">
                    <field-map field-name="instrumentId" from="localInstrumentId"/>
                </entity-find-one>
                <if condition="lc?.effectiveAmount">
                    <set field="evaluationAmount" from="lc.effectiveAmount"/>
                </if>
            </if>
            
            <!-- Check Four-Eyes: Cannot approve own submission -->
            <if condition="transactionId">
                <entity-find-one entity-name="trade.TradeTransaction" value-field="makerTx">
                    <field-map field-name="transactionId"/>
                </entity-find-one>
                <if condition="makerTx?.makerUserId == userId">
                    <set field="isAuthorized" from="false" type="Boolean"/>
                    <return/>
                </if>
            </if>
            <if condition="!transactionId">
                <entity-find entity-name="trade.TradeTransactionAudit" list="makerAudits">
                    <econdition field-name="instrumentId" from="localInstrumentId"/>
                    <econdition field-name="actionEnumId" value="MAKER_COMMIT"/>
                </entity-find>
                <if condition="makerAudits &amp;&amp; makerAudits[0].userId == userId">
                    <set field="isAuthorized" from="false" type="Boolean"/>
                    <return/>
                </if>
            </if>
            
            <!-- Check User Authority Tier -->
            <entity-find entity-name="trade.UserAuthorityProfile" list="profiles">
                <econdition field-name="userId"/>
                <econdition field-name="isSuspended" operator="not-equals" value="Y"/>
                <order-by field-name="customLimit"/>
            </entity-find>
            <if condition="!profiles">
                <set field="isAuthorized" from="false" type="Boolean"/>
                <return/>
            </if>
            
            <set field="isAuthorized" value="false" type="Boolean"/>
            <iterate list="profiles" entry="profile">
                <if condition="evaluationAmount &lt;= (profile.customLimit ?: BigDecimal.ZERO)">
                    <set field="isAuthorized" value="true" type="Boolean"/>
                    <set field="authorityTierEnumId" from="profile.delegationTierId"/>
                    <break/>
                </if>
            </iterate>
        </actions>
    </service>
    <service verb="authorize" noun="Instrument" authenticate="false">
        <in-parameters>
            <parameter name="instrumentId"/>
            <parameter name="transactionId"/>
            <parameter name="userId" default="ec.user.userId ?: 'EXOR_SERVICE_USER'"/>
            <parameter name="skipFourEyes" type="Boolean" default="false"/>
        </in-parameters>
        <out-parameters>
            <parameter name="isAuthorized" type="Boolean"/>
        </out-parameters>
        <actions>
            <script>ec.artifactExecution.disableAuthz()</script>
            <service-call name="trade.AuthorizationServices.evaluate#MakerCheckerMatrix" in-map="context + [skipFourEyes: skipFourEyes]" out-map="evalOut"/>
            <set field="isAuthorized" from="evalOut.isAuthorized"/>
            
            <if condition="isAuthorized">
                <if condition="transactionId">
                    <entity-find-one entity-name="trade.TradeTransaction" value-field="tx" auto-field-map="true"/>
                    <if condition="!tx"><return error="true" message="Transaction ${transactionId} not found"/></if>
                    <if condition="tx.transactionStatusId == 'TX_APPROVED'">
                        <return error="true" message="Transaction ${transactionId} is already approved"/>
                    </if>
                    
                    <entity-find-one entity-name="trade.TradeInstrument" value-field="inst">
                        <field-map field-name="instrumentId" from="tx.instrumentId"/>
                    </entity-find-one>

                    <!-- Dynamically calculate target values -->
                    <set field="targetState" from="null"/>
                    <set field="targetAmount" from="inst.amount"/>
                    <set field="targetExpiry" from="inst.expiryDate"/>

                    <!-- Fetch Import LC Specifics if available -->
                    <entity-find-one entity-name="trade.importlc.ImportLetterOfCredit" value-field="lc" for-update="true">
                        <field-map field-name="instrumentId" from="tx.instrumentId"/>
                    </entity-find-one>

                    <if condition="tx.transactionTypeEnumId == 'IMP_NEW'">
                        <set field="targetAmount" from="lc?.effectiveAmount ?: targetAmount"/>
                        <set field="targetExpiry" from="lc?.effectiveExpiryDate ?: targetExpiry"/>
                        
                        <!-- Update Facility Utilization for New LC -->
                        <if condition="inst.customerFacilityId">
                            <set field="liabilityAmount" from="targetAmount * (1 + (lc?.tolerancePositive ?: 0))"/>
                            <service-call name="trade.LimitServices.update#Utilization" 
                                          in-map="[facilityId: inst.customerFacilityId, amountDelta: liabilityAmount]"/>
                        </if>
                    </if>
                    <if condition="tx.transactionTypeEnumId == 'IMP_AMENDMENT'">
                        <entity-find-one entity-name="trade.importlc.ImportLcAmendment" value-field="amd">
                            <field-map field-name="amendmentId" from="tx.relatedRecordId"/>
                        </entity-find-one>
                        <set field="targetAmount" from="(inst.amount ?: 0) + (amd?.amountAdjustment ?: 0)"/>
                        <set field="targetExpiry" from="amd?.newExpiryDate ?: targetExpiry"/>
                        
                        <service-call name="update#trade.importlc.ImportLcAmendment" in-map="[
                            amendmentId: tx.relatedRecordId,
                            amendmentBusinessStateId: 'AMEND_APPROVED'
                        ]"/>
                    </if>
                    
                    <if condition="tx.transactionTypeEnumId == 'IMP_SETTLEMENT'">
                        <entity-find-one entity-name="trade.importlc.ImportLcSettlement" value-field="settlement">
                            <field-map field-name="settlementId" from="tx.relatedRecordId"/>
                        </entity-find-one>
                        
                        <log level="info" message="Authorizing settlement: ${settlement?.settlementId}, amount: ${settlement?.principalAmount}, current LC balance: ${lc?.effectiveOutstandingAmount}"/>
                        
                        <script><![CDATA[
                            def principal = (BigDecimal) (settlement?.principalAmount ?: 0)
                            def currentOutstanding = (BigDecimal) (lc.effectiveOutstandingAmount ?: 0)
                            def currentCumulative = (BigDecimal) (lc.cumulativeDrawnAmount ?: 0)
                            
                            def newOutstanding = currentOutstanding - principal
                            if (newOutstanding < 0) newOutstanding = 0
                            def newCumulative = currentCumulative + principal
                            
                            lc.effectiveOutstandingAmount = newOutstanding
                            lc.cumulativeDrawnAmount = newCumulative
                            
                            ec.logger.info("Authorizing settlement ${settlement?.settlementId} for LC ${lc.instrumentId}. Amount: ${principal}, Balance: ${currentOutstanding} -> ${newOutstanding}")
                            
                            if (newOutstanding.signum() == 0) {
                                if (lc.isRevolving == 'Y') {
                                    ec.logger.info("Reinstating revolving LC ${lc.instrumentId}")
                                    lc.effectiveOutstandingAmount = (BigDecimal) lc.effectiveAmount
                                    lc.businessStateId = "LC_ISSUED"
                                    targetState = "LC_ISSUED"
                                } else {
                                    ec.logger.info("Settlement complete. Closing LC ${lc.instrumentId}")
                                    lc.businessStateId = "LC_CLOSED"
                                    targetState = "LC_CLOSED"
                                }
                            } else {
                                ec.logger.info("Partial settlement. LC ${lc.instrumentId} remains ISSUED. Balance: ${newOutstanding}")
                                lc.businessStateId = "LC_ISSUED"
                                targetState = "LC_ISSUED"
                            }
                        ]]></script>
                        <entity-update value-field="lc"/>
                    </if>

                    <if condition="tx.transactionTypeEnumId == 'IMP_CANCELLATION'">
                        <set field="targetState" value="LC_CANCELLED"/>
                    </if>
                    
                    <if condition="tx.transactionTypeEnumId == 'IMP_SG_ISSUANCE'">
                         <service-call name="update#trade.importlc.ImportLcShippingGuarantee" in-map="[
                            guaranteeId: tx.relatedRecordId,
                            sgStatusId: 'SG_ISSUED'
                        ]"/>
                    </if>
                    
                    <!-- Commit to Master Data -->
                    <service-call name="update#trade.TradeInstrument" in-map="[
                        instrumentId: tx.instrumentId,
                        businessStateId: 'INST_AUTHORIZED',
                        amount: targetAmount,
                        expiryDate: targetExpiry
                    ]"/>

                    <service-call name="update#trade.TradeTransaction" in-map="[
                        transactionId: transactionId,
                        transactionStatusId: 'TX_APPROVED',
                        checkerUserId: userId,
                        checkerTimestamp: ec.user.nowTimestamp
                    ]"/>

                    <!-- Update Import LC Specifics -->
                    <if condition="lc">
                        <if condition="!targetState">
                            <if condition="tx.transactionTypeEnumId == 'IMP_NEW'"><set field="targetState" value="LC_ISSUED"/></if>
                            <if condition="tx.transactionTypeEnumId == 'IMP_AMENDMENT'"><set field="targetState" value="LC_AMENDED"/></if>
                            <if condition="tx.transactionTypeEnumId == 'IMP_PRESENTATION'"><set field="targetState" value="LC_DOC_RECEIVED"/></if>
                            <!-- If still not set, default to current state to avoid accidental transition to LC_ISSUED -->
                            <if condition="!targetState"><set field="targetState" from="lc.businessStateId"/></if>
                        </if>
                        
                        <set field="lcUpdateInMap" from="[instrumentId: tx.instrumentId, businessStateId: targetState, lcAmount: targetAmount, expiryDate: targetExpiry, skipImmutabilityGuard: true]"/>
                        <if condition="tx.transactionTypeEnumId == 'IMP_AMENDMENT' &amp;&amp; amd">
                            <set field="lcUpdateInMap.goodsDescription" from="amd.goodsDescription"/>
                            <set field="lcUpdateInMap.documentsRequired" from="amd.documentsRequired"/>
                            <set field="lcUpdateInMap.additionalConditions" from="amd.additionalConditions"/>
                            <set field="lcUpdateInMap.bankToBankInstructions" from="amd.bankToBankInstructions"/>
                            <set field="lcUpdateInMap.additionalAmountsText" from="amd.additionalAmountsText"/>
                            <set field="lcUpdateInMap.chargeAllocationText" from="amd.chargeAllocationText"/>
                            <set field="lcUpdateInMap.shipmentPeriodText" from="amd.shipmentPeriodText"/>
                        </if>
                        <service-call name="trade.importlc.ImportLcServices.update#ImportLetterOfCredit" in-map="lcUpdateInMap"/>
                    </if>
                </if>
            </if>
            <script>ec.artifactExecution.enableAuthz()</script>
        </actions>
    </service>
    <service verb="get" noun="PendingApprovals" authenticate="false">
        <out-parameters>
            <parameter name="approvalsList" type="List">
                <parameter name="item" type="Map"/>
            </parameter>
        </out-parameters>
        <actions>
            <script>ec.artifactExecution.disableAuthz()</script>
            <entity-find entity-name="trade.TradeTransaction" list="pendingList">
                <econdition field-name="transactionStatusId" value="TX_PENDING"/>
                <order-by field-name="-makerTimestamp"/>
            </entity-find>
            <set field="approvalsList" from="[]"/>
            <iterate list="pendingList" entry="tx">
                <entity-find-one entity-name="trade.TradeInstrument" value-field="inst">
                    <field-map field-name="instrumentId" from="tx.instrumentId"/>
                </entity-find-one>

                <!-- Calculate Transaction-Specific Amount -->
                <set field="transactionAmount" from="0" type="BigDecimal"/>
                <if condition="tx.transactionTypeEnumId == 'IMP_NEW'">
                    <set field="transactionAmount" from="inst?.amount"/>
                </if>
                <if condition="tx.transactionTypeEnumId == 'IMP_AMENDMENT'">
                    <entity-find-one entity-name="trade.importlc.ImportLcAmendment" value-field="amd">
                        <field-map field-name="amendmentId" from="tx.relatedRecordId"/>
                    </entity-find-one>
                    <set field="transactionAmount" from="amd?.amountAdjustment ?: 0"/>
                </if>
                <if condition="tx.transactionTypeEnumId == 'IMP_PRESENTATION'">
                    <entity-find-one entity-name="trade.importlc.TradeDocumentPresentation" value-field="pres">
                        <field-map field-name="presentationId" from="tx.relatedRecordId"/>
                    </entity-find-one>
                    <set field="transactionAmount" from="pres?.claimAmount ?: 0"/>
                </if>
                <if condition="tx.transactionTypeEnumId == 'IMP_SETTLEMENT'">
                    <entity-find-one entity-name="trade.importlc.ImportLcSettlement" value-field="stl">
                        <field-map field-name="settlementId" from="tx.relatedRecordId"/>
                    </entity-find-one>
                    <set field="transactionAmount" from="stl?.principalAmount ?: 0"/>
                </if>

                <set field="item" from="[
                    instrumentId: tx.instrumentId,
                    instrumentRef: inst?.instrumentRef,
                    transactionRef: tx.transactionRef ?: tx.transactionId,
                    transactionId: tx.transactionId,
                    module: inst?.instrumentTypeEnumId == 'IMPORT_LC' ? 'IMPORT LC' : inst?.instrumentTypeEnumId,
                    action: tx.transactionTypeEnumId.replace('IMP_', '').replace('_', ' '),
                    makerUserId: tx.makerUserId,
                    baseEquivalentAmount: inst?.baseEquivalentAmount,
                    transactionAmount: transactionAmount,
                    priorityEnumId: tx.priorityEnumId ?: 'NORMAL',
                    transactionStatusId: tx.transactionStatusId,
                    transactionTypeEnumId: tx.transactionTypeEnumId,
                    timeInQueue: '0h'
                ]"/>

                <if condition="tx.makerTimestamp">
                    <set field="diffMs" from="ec.user.nowTimestamp.time - tx.makerTimestamp.time"/>
                    <set field="hours" from="(diffMs / (1000 * 60 * 60)).toInteger()"/>
                    <set field="item.timeInQueue" from="hours + 'h'"/>
                </if>
                <script>approvalsList.add(item)</script>
            </iterate>
            <script>ec.artifactExecution.enableAuthz()</script>
        </actions>
    </service>

    <service verb="reject" noun="Instrument" authenticate="false">
        <in-parameters>
            <parameter name="instrumentId" required="true"/>
            <parameter name="rejectionReason"/>
            <parameter name="userId" default="ec.user.userId ?: 'EXOR_SERVICE_USER'"/>
        </in-parameters>
        <actions>
            <script>ec.artifactExecution.disableAuthz()</script>
            
            <!-- Find pending transaction -->
            <entity-find entity-name="trade.TradeTransaction" list="txList">
                <econdition field-name="instrumentId"/>
                <econdition field-name="transactionStatusId" value="TX_PENDING"/>
                <order-by field-name="-transactionId"/>
            </entity-find>
            <if condition="txList">
                <service-call name="update#trade.TradeTransaction" 
                              in-map="[transactionId: txList[0].transactionId, 
                                       transactionStatusId: 'TX_DRAFT', 
                                       rejectionReason: rejectionReason,
                                       checkerUserId: userId,
                                       checkerTimestamp: ec.user.nowTimestamp]"/>
                
                <!-- Create audit record -->
                <service-call name="create#trade.TradeTransactionAudit"
                    in-map="[transactionId: txList[0].transactionId,
                             instrumentId: instrumentId,
                             userId: userId,
                             actionEnumId: 'CHECKER_REJECT',
                             oldValue: 'TX_PENDING',
                             newValue: 'TX_DRAFT',
                             justificationRootText: rejectionReason]"/>
            </if>
            
            <!-- Update business state to LC_DRAFT -->
            <entity-find-one entity-name="trade.importlc.ImportLetterOfCredit" value-field="lc" for-update="true">
                <field-map field-name="instrumentId"/>
            </entity-find-one>
            <if condition="lc &amp;&amp; lc.businessStateId != 'LC_DRAFT'">
                <set field="oldBusinessState" from="lc.businessStateId"/>
                <set field="lc.businessStateId" value="LC_DRAFT"/>
                <entity-update value-field="lc"/>
                
                <service-call name="create#trade.TradeTransactionAudit"
                    in-map="[instrumentId: instrumentId,
                             userId: userId,
                             actionEnumId: 'BUSINESS_STATE_CHANGE',
                             oldValue: oldBusinessState,
                             newValue: 'LC_DRAFT']"/>
            </if>
        </actions>
    </service>
</services>
