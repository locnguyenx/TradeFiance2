<?xml version="1.0" encoding="UTF-8"?>
<services xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/service-definition-3.0.xsd">

    <!-- ABOUTME: ImportLcServices manages the lifecycle of Import Letters of Credit, including creation, versioning, and status transitions. -->

    <service verb="create" noun="LetterOfCredit" authenticate="false">
        <in-parameters>
            <!-- TradeInstrument fields -->
            <parameter name="transactionRef" required="true"/>
            
            <!-- ImportLetterOfCredit fields -->
            <auto-parameters entity-name="moqui.trade.importlc.ImportLetterOfCredit" include="nonpk"/>
            <parameter name="lcAmount" type="BigDecimal" required="true"/>
            <parameter name="lcCurrencyUomId" required="true"/>
            <parameter name="expiryDate" type="Date"/>
            <parameter name="latestShipmentDate" type="Date"/>
        </in-parameters>
        <out-parameters>
            <parameter name="instrumentId" required="true"/>
        </out-parameters>
        <actions>
            <!-- 1. Create TradeInstrument -->
            <service-call name="create#moqui.trade.instrument.TradeInstrument" out-map="createInstOut"
                in-map="[
                    transactionRef: transactionRef,
                    instrumentTypeEnumId: 'IMPORT_LC',
                    transactionStatusId: 'TX_DRAFT',
                    makerUserId: ec.user.userId,
                    makerTimestamp: ec.user.nowTimestamp,
                    amount: lcAmount,
                    currencyUomId: lcCurrencyUomId,
                    expiryDate: expiryDate,
                    versionNumber: 1
                ]"/>
            <set field="instrumentId" from="createInstOut.instrumentId"/>

            <!-- 2. Create ImportLetterOfCredit -->
            <service-call name="create#moqui.trade.importlc.ImportLetterOfCredit"
                in-map="context + [
                    instrumentId: instrumentId,
                    effectiveAmount: lcAmount,
                    effectiveOutstandingAmount: lcAmount,
                    effectiveExpiryDate: expiryDate,
                    effectiveShipmentDate: latestShipmentDate,
                    effectiveCurrencyUomId: lcCurrencyUomId
                ]"/>
        </actions>
    </service>

    <service verb="update" noun="LetterOfCredit" authenticate="false">
        <in-parameters>
            <parameter name="instrumentId" required="true"/>
            <auto-parameters entity-name="moqui.trade.instrument.TradeInstrument" include="nonpk"/>
            <auto-parameters entity-name="moqui.trade.importlc.ImportLetterOfCredit" include="nonpk"/>
            <parameter name="lcAmount" type="BigDecimal"/>
            <parameter name="lcCurrencyUomId"/>
            <parameter name="expiryDate" type="Date"/>
            <parameter name="latestShipmentDate" type="Date"/>
        </in-parameters>
        <actions>
            <entity-find-one entity-name="moqui.trade.instrument.TradeInstrument" value-field="instrument" auto-field-map="true"/>
            <if condition="!instrument"><return error="true" message="Letter of Credit not found with ID ${instrumentId}"/></if>

            <!-- Versioning Logic -->
            <if condition="instrument.transactionStatusId == 'TX_APPROVED'">
                <set field="instrument.versionNumber" from="(instrument.versionNumber ?: 1) + 1"/>
                <set field="instrument.transactionStatusId" value="TX_DRAFT"/>
            </if>

            <if condition="lcAmount != null"><set field="instrument.amount" from="lcAmount"/></if>
            <if condition="lcCurrencyUomId != null"><set field="instrument.currencyUomId" from="lcCurrencyUomId"/></if>
            <if condition="expiryDate != null"><set field="instrument.expiryDate" from="expiryDate"/></if>
            <set field="instrument.lastUpdateTimestamp" from="ec.user.nowTimestamp"/>
            <entity-update value-field="instrument"/>

            <entity-find-one entity-name="moqui.trade.importlc.ImportLetterOfCredit" value-field="lc" auto-field-map="true"/>
            <if condition="lcAmount != null">
                <set field="lc.effectiveAmount" from="lcAmount"/>
                <set field="lc.effectiveOutstandingAmount" from="lcAmount"/>
            </if>
            <if condition="lcCurrencyUomId != null"><set field="lc.effectiveCurrencyUomId" from="lcCurrencyUomId"/></if>
            <if condition="expiryDate != null"><set field="lc.effectiveExpiryDate" from="expiryDate"/></if>
            <if condition="latestShipmentDate != null"><set field="lc.effectiveShipmentDate" from="latestShipmentDate"/></if>
            <entity-update value-field="lc"/>
        </actions>
    </service>
    <service verb="approve" noun="LetterOfCredit" authenticate="false">
        <in-parameters>
            <parameter name="instrumentId" required="true"/>
            <parameter name="approverUserId"/>
            <parameter name="approvalComments"/>
        </in-parameters>
        <actions>
            <entity-find-one entity-name="moqui.trade.instrument.TradeInstrument" value-field="instrument" auto-field-map="true"/>
            <if condition="!instrument"><return error="true" message="Instrument not found with ID ${instrumentId}"/></if>

            <if condition="!(instrument.transactionStatusId in ['TX_DRAFT', 'TX_APPROVED'])">
                <return error="true" message="Only Draft or Approved instruments can be approved (current status: ${instrument.transactionStatusId})"/>
            </if>

            <!-- 1. Create Approval Record -->
            <set field="approverUserId" from="approverUserId ?: ec.user.userId"/>
            <service-call name="create#moqui.trade.instrument.TradeApprovalRecord"
                in-map="[
                    instrumentId: instrumentId,
                    approverUserId: approverUserId,
                    approvalTimestamp: ec.user.nowTimestamp,
                    approvalComments: approvalComments,
                    versionSnapshot: instrument.versionNumber
                ]"/>

            <!-- 2. Update Instrument Status -->
            <set field="instrument.transactionStatusId" value="TX_APPROVED"/>
            <set field="instrument.checkerUserId" from="approverUserId"/>
            <set field="instrument.checkerTimestamp" from="ec.user.nowTimestamp"/>
            <entity-update value-field="instrument"/>
        </actions>
    </service>

    <service verb="create" noun="Amendment" authenticate="false">
        <in-parameters>
            <parameter name="instrumentId" type="String" required="true"/>
            <parameter name="amendmentTypeEnumId" type="String" required="true"/>
            <parameter name="amendmentDate" type="Date" required="true"/>
            <parameter name="amountAdjustment" type="BigDecimal"/>
            <parameter name="newExpiryDate" type="Date"/>
            <parameter name="amendmentNarrative" type="String"/>
            <parameter name="isFinancial" type="String"/>
        </in-parameters>
        <out-parameters>
            <parameter name="amendmentId" type="String"/>
        </out-parameters>
        <actions>
            <entity-find-one entity-name="moqui.trade.instrument.TradeInstrument" value-field="instrument"/>
            <if condition="!instrument"><return error="true" message="Instrument ${instrumentId} not found"/></if>
            
            <service-call name="create#moqui.trade.importlc.ImportLcAmendment" out-map="context"
                in-map="context + [amendmentBusinessStateId: 'AMEND_DRAFT', isFinancial: isFinancial ?: 'N']"/>
        </actions>
    </service>

    <service verb="authorize" noun="Amendment" authenticate="false">
        <in-parameters>
            <parameter name="amendmentId" type="String" required="true"/>
        </in-parameters>
        <actions>
            <entity-find-one entity-name="moqui.trade.importlc.ImportLcAmendment" value-field="amendment" for-update="true"/>
            <if condition="!amendment"><return error="true" message="Amendment ${amendmentId} not found"/></if>

            <if condition="amendment.amendmentBusinessStateId != 'AMEND_DRAFT'">
                <return error="true" message="Only amendments in DRAFT state can be authorized (current: ${amendment.amendmentBusinessStateId})"/>
            </if>

            <set field="amendment.amendmentBusinessStateId" value="AMEND_APPROVED"/>
            <entity-update value-field="amendment"/>

            <entity-find-one entity-name="moqui.trade.importlc.ImportLetterOfCredit" value-field="lc" for-update="true">
                <field-map field-name="instrumentId" from="amendment.instrumentId"/>
            </entity-find-one>
            <if condition="lc">
                <set field="lc.effectiveAmount" from="(lc.effectiveAmount ?: 0) + amendment.amountAdjustment"/>
                <set field="lc.effectiveOutstandingAmount" from="(lc.effectiveOutstandingAmount ?: 0) + amendment.amountAdjustment"/>
                <set field="lc.totalAmendmentCount" from="(lc.totalAmendmentCount ?: 0) + 1"/>
                <entity-update value-field="lc"/>
            </if>

            <entity-find-one entity-name="moqui.trade.instrument.TradeInstrument" value-field="instrument" for-update="true">
                <field-map field-name="instrumentId" from="amendment.instrumentId"/>
            </entity-find-one>
            <if condition="instrument">
                <set field="instrument.versionNumber" from="(instrument.versionNumber ?: 1) + 1"/>
                <if condition="instrument.transactionStatusId == 'TX_APPROVED'">
                    <set field="instrument.transactionStatusId" value="TX_DRAFT"/>
                </if>
                <entity-update value-field="instrument"/>
            </if>
        </actions>
    </service>

    <service verb="settle" noun="Presentation" authenticate="false">
        <in-parameters>
            <parameter name="presentationId" type="String" required="true"/>
            <parameter name="settlementAmount" type="BigDecimal" required="true"/>
            <parameter name="settlementTypeEnumId" type="String" required="true"/>
            <parameter name="isPartialDraw" type="String" default="Y"/>
        </in-parameters>
        <actions>
            <entity-find-one entity-name="moqui.trade.importlc.TradeDocumentPresentation" value-field="presentation"/>
            <if condition="!presentation"><return error="true" message="Presentation ${presentationId} not found"/></if>
            <set field="instrumentId" from="presentation.instrumentId"/>

            <entity-find-one entity-name="moqui.trade.importlc.ImportLetterOfCredit" value-field="lc" for-update="true"/>
            
            <service-call name="create#moqui.trade.importlc.ImportLcSettlement" in-map="context"/>

            <!-- Update Presentation Status -->
            <set field="presentation.presentationStatusId" value="PRES_SETTLED"/>
            <entity-update value-field="presentation"/>

            <!-- Drawdown LC Effective Values -->
            <set field="lc.effectiveOutstandingAmount" from="lc.effectiveOutstandingAmount - settlementAmount"/>
            <set field="lc.cumulativeDrawnAmount" from="(lc.cumulativeDrawnAmount ?: 0) + settlementAmount"/>
            <entity-update value-field="lc"/>
        </actions>
    </service>
</services>
