<?xml version="1.0" encoding="UTF-8"?>
<!-- ABOUTME: TradeCommonEntities defines shared instruments and credit facility structures for all trade modules. -->
<entities xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/entity-definition-3.0.xsd">

    <entity entity-name="TradeInstrument" package="trade">
        <field name="instrumentId" type="id" is-pk="true"/>
        <field name="transactionRef" type="text-short"/>
        <field name="lifecycleStatusId" type="id"/>
        <field name="businessStateId" type="id"/>
        <field name="previousBusinessStateId" type="id"/>
        <field name="instrumentTypeEnumId" type="id"/>
        <field name="productEnumId" type="id"/>
        <field name="amount" type="number-decimal"/>
        <field name="currencyUomId" type="id"/>
        <field name="outstandingAmount" type="number-decimal"/>
        <field name="baseEquivalentAmount" type="number-decimal"/>
        <field name="applicantPartyId" type="id"/>
        <field name="beneficiaryPartyId" type="id"/>
        <field name="issueDate" type="date"/>
        <field name="expiryDate" type="date"/>
        <field name="customerFacilityId" type="id"/>
        <!-- Transaction Management Fields -->
        <field name="transactionDate" type="date"/>
        <field name="transactionTypeEnumId" type="id"/>
        <field name="transactionStatusId" type="id"/>
        <field name="makerUserId" type="id"/>
        <field name="makerTimestamp" type="date-time"/>
        <field name="checkerUserId" type="id"/>
        <field name="checkerTimestamp" type="date-time"/>
        <field name="rejectionReason" type="text-long"/>
        <field name="versionNumber" type="number-integer"/>
        <field name="lastUpdateTimestamp" type="date-time"/>
        <field name="priorityEnumId" type="id"/>
    </entity>

    <entity entity-name="CustomerFacility" package="trade">
        <field name="facilityId" type="id" is-pk="true"/>
        <field name="ownerPartyId" type="id"/>
        <field name="totalApprovedLimit" type="number-decimal"/>
        <field name="utilizedAmount" type="number-decimal"/>
        <field name="currencyUomId" type="id"/>
        <field name="facilityExpiryDate" type="date"/>
    </entity>

    <entity entity-name="TradeTransactionAudit" package="trade">
        <field name="instrumentId" type="id" is-pk="true"/>
        <field name="auditId" type="id" is-pk="true"/>
        <field name="timestamp" type="date-time" default="ec.user.nowTimestamp"/>
        <field name="userId" type="id"/>
        <field name="actionEnumId" type="id"/>
        <field name="requestIpAddress" type="text-short"/>
        <field name="changedFieldName" type="text-medium"/>
        <field name="oldValue" type="text-long"/>
        <field name="newValue" type="text-long"/>
        <field name="justificationRootText" type="text-long"/>
        <field name="snapshotDeltaJSON" type="text-very-long"/>
    </entity>

    <entity entity-name="TradeStandardClause" package="trade.common">
        <field name="clauseId" type="id" is-pk="true"/>
        <field name="clauseTypeEnumId" type="id"/>
        <field name="clauseName" type="text-medium"/>
        <field name="clauseText" type="text-very-long"/>
    </entity>

    <entity entity-name="TradeConfig" package="trade.common">
        <field name="configId" type="id" is-pk="true"/>
        <field name="configKey" type="text-medium"/>
        <field name="configValue" type="text-medium"/>
        <field name="description" type="text-medium"/>
    </entity>

    <entity entity-name="TradeAuditLog" package="trade.common">
        <field name="auditLogId" type="id" is-pk="true"/>
        <field name="changedByUserId" type="id"/>
        <field name="timestamp" type="date-time" default-field-direct="true"/>
        <field name="actionName" type="text-medium"/>
        <field name="deltaJson" type="text-very-long"/>
        <field name="transactionRef" type="text-medium"/>
    </entity>
    <entity entity-name="TradeParty" package="trade">
        <field name="partyId" type="id" is-pk="true"/>
        <field name="partyName" type="text-medium"/>
        <field name="kycStatus" type="text-short"/> <!-- Active, Expired -->
        <field name="kycExpiryDate" type="date"/>
        <field name="sanctionsStatus" type="text-short"/> <!-- Clear, Suspended, Blocked -->
        <field name="countryOfRisk" type="id"/> <!-- ISO Country Code -->
        <field name="swiftBic" type="text-short"/>
        <field name="registeredAddress" type="text-long"/> <!-- 4x35 SWIFT format -->
        <field name="partyRoleEnumId" type="id"/>
    </entity>
    
    <entity entity-name="FeeConfiguration" package="trade">
        <field name="feeConfigurationId" type="id" is-pk="true"/>
        <field name="feeEventEnumId" type="id"/> <!-- ISSUANCE_FEE, AMENDMENT_FEE, etc. -->
        <field name="calculationTypeEnumId" type="id"/> <!-- FLAT, PERCENTAGE, TIERED -->
        <field name="baseValue" type="number-decimal"/> <!-- Unified rate or flat amt -->
        <field name="ratePercent" type="number-decimal"/> <!-- Legacy field for back-compat if needed, migrating to baseValue -->
        <field name="flatAmount" type="number-decimal"/> <!-- Legacy field -->
        <field name="minFloorAmount" type="number-decimal"/>
        <field name="maxCeilingAmount" type="number-decimal"/>
        <field name="currencyUomId" type="id"/>
        <field name="frequencyEnumId" type="id"/> <!-- ONCE, MONTHLY, QUARTERLY -->
        <field name="effectiveDate" type="date"/>
        <field name="customerTierOverride" type="text-short"/>
        <field name="statusId" type="id" default="'FEE_ACTIVE'"/> <!-- FEE_DRAFT, FEE_ACTIVE -->
        <field name="isActive" type="text-indicator" default="'Y'"/>
    </entity>

    <entity entity-name="TradeProductCatalog" package="trade">
        <field name="productId" type="id" is-pk="true"/>
        <field name="productTypeEnumId" type="id"/> <!-- IMP_LC, EXP_LC, etc. -->
        <field name="productName" type="text-medium"/>
        <field name="productDescription" type="text-long"/>
        <field name="isActive" type="text-indicator" default="'Y'"/>
        <field name="statusId" type="id" default="'PROD_ACTIVE'"/>
        <!-- Common Constraints -->
        <field name="allowedTenorEnumId" type="id"/>
        <field name="maxToleranceLimit" type="number-integer"/> <!-- Percentage e.g. 10 for 10% -->
        <!-- Product Specific Flags -->
        <field name="allowRevolving" type="text-indicator" default="'N'"/>
        <field name="allowAdvancePayment" type="text-indicator" default="'N'"/>
        <field name="isStandby" type="text-indicator" default="'N'"/>
        <field name="isTransferable" type="text-indicator" default="'N'"/>
        <field name="accountingFrameworkEnumId" type="id"/>
        <field name="mandatoryMarginPercent" type="number-integer"/>
        <field name="documentExamSlaDays" type="number-integer" default="5"/>
        <field name="defaultSwiftFormatEnumId" type="id"/>
    </entity>

    <entity entity-name="UserAuthorityProfile" package="trade">
        <field name="userAuthorityId" type="id" is-pk="true"/>
        <field name="userId" type="id"/>
        <field name="makerCheckerFlag" type="id" default="'MAKER_CHECKER'"/> <!-- MAKER, CHECKER, DUAL -->
        <field name="delegationTierId" type="id"/> <!-- TIER_1, TIER_2, etc. -->
        <field name="customLimit" type="number-decimal"/>
        <field name="currencyUomId" type="id"/>
        <field name="branchAccessList" type="text-long"/> <!-- JSON or CSV of allowed branch IDs -->
        <field name="isSuspended" type="text-indicator" default="'N'"/>
    </entity>

    <entity entity-name="TradeApprovalRecord" package="trade">
        <field name="approvalRecordId" type="id" is-pk="true"/>
        <field name="instrumentId" type="id"/>
        <field name="approverUserId" type="id"/>
        <field name="approvalTimestamp" type="date-time" default="ec.user.nowTimestamp"/>
        <field name="approvalComments" type="text-long"/>
        <field name="versionSnapshot" type="number-integer"/>
        <relationship type="one" related="trade.TradeInstrument" title="Instrument">
            <key-map field-name="instrumentId"/>
        </relationship>
    </entity>

    <entity entity-name="NumberSequence" package="trade.common">
        <field name="sequenceId" type="id" is-pk="true"/>
        <field name="prefix" type="text-short"/>
        <field name="lastNumber" type="number-integer" default="0"/>
        <field name="description" type="text-medium"/>
    </entity>
</entities>
