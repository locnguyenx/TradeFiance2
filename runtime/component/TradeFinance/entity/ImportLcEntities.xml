<?xml version="1.0" encoding="UTF-8"?>
<!-- ABOUTME: ImportLcEntities extends core trade instruments with SWIFT-compliant fields for Letters of Credit. -->
<entities xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/entity-definition-3.0.xsd">

    <entity entity-name="ImportLetterOfCredit" package="trade.importlc">
        <field name="instrumentId" type="id" is-pk="true"/>
        <field name="businessStateId" type="id"/>
        <field name="tolerancePositive" type="number-decimal"/>
        <field name="toleranceNegative" type="number-decimal"/>
        <field name="tenorTypeId" type="id"/>
        <field name="usanceDays" type="number-integer"/>
        <field name="portOfLoading" type="text-medium"/>
        <field name="portOfDischarge" type="text-medium"/>
        <field name="expiryPlace" type="text-medium"/>
        <field name="goodsDescription" type="text-very-long"/>
        <field name="documentsRequired" type="text-very-long"/>
        <field name="additionalConditions" type="text-very-long"/>
        
        <!-- New Specification Fields -->
        <field name="chargeAllocationEnumId" type="id"/>
        <field name="partialShipmentEnumId" type="id"/>
        <field name="transhipmentEnumId" type="id"/>
        <field name="latestShipmentDate" type="date"/>
        <field name="confirmationEnumId" type="id"/>
        <field name="lcTypeEnumId" type="id"/>
        <field name="availableByEnumId" type="id"/>
        <field name="availableWithEnumId" type="id"/> <!-- AvailableWithType -->
        <field name="productCatalogId" type="id"/>

        <!-- Effective Values (Snapshot vs Last Effective Pattern) -->
        <field name="effectiveAmount" type="number-decimal"/>
        <field name="effectiveCurrencyUomId" type="id"/>
        <field name="effectiveExpiryDate" type="date"/>
        <field name="effectiveShipmentDate" type="date"/>
        <field name="effectiveTolerancePositive" type="number-decimal"/>
        <field name="effectiveToleranceNegative" type="number-decimal"/>
        <field name="effectiveOutstandingAmount" type="number-decimal"/>
        <field name="isRevolving" type="text-indicator" default="'N'"/>
        <field name="cumulativeDrawnAmount" type="number-decimal" default="0"/>
        <field name="totalAmendmentCount" type="number-integer" default="0"/>
        
        <field name="receiptPlace" type="text-medium"/> <!-- Tag 44A: max 65, X charset -->
        <field name="finalDeliveryPlace" type="text-medium"/> <!-- Tag 44B: max 65, X charset -->
        <field name="shipmentPeriodText" type="text-medium"/> <!-- Tag 44D: max 65, X charset. Mutually exclusive with latestShipmentDate -->
        <field name="maxCreditAmountFlag" type="text-indicator"/> <!-- Tag 39B: Y/N. Mutually exclusive with tolerance -->
        <field name="additionalAmountsText" type="text-long"/> <!-- Tag 39C: max 4x35, X charset -->
        <field name="mixedPaymentDetails" type="text-long"/> <!-- Tag 42M: required if tenor=MIXED -->
        <field name="deferredPaymentDetails" type="text-long"/> <!-- Tag 42P: required if tenor=DEF_PAYMENT/NEGOTIATION -->
        <field name="usanceBaseDate" type="text-medium"/> <!-- Tag 42C: required if tenor!=SIGHT -->
        <field name="bankToBankInstructions" type="text-very-long"/> <!-- Tag 78: max 12x65, X charset -->
        <field name="presentationPeriodDays" type="number-integer"/> <!-- Tag 48 -->
        <field name="chargeAllocationText" type="text-long"/> <!-- Tag 71D: max 6x35, X charset -->

        <relationship type="one" related="trade.TradeInstrument">
            <key-map field-name="instrumentId"/>
        </relationship>
        <relationship type="one" related="trade.TradeProductCatalog">
            <key-map field-name="productCatalogId" related="productId"/>
        </relationship>
    </entity>

    <entity entity-name="SwiftMessage" package="trade.importlc">
        <field name="swiftMessageId" type="id" is-pk="true"/>
        <field name="instrumentId" type="id"/>
        <field name="messageType" type="text-short"/> <!-- e.g., MT700 -->
        <field name="messageContent" type="text-very-long"/>
        <field name="generatedDate" type="date-time" default="ec.user.nowTimestamp"/>
        <field name="messageStatusId" type="id"/> <!-- SWIFT_MSG_DRAFT or SWIFT_MSG_ACTIVE -->
        
        <relationship type="one" related="trade.TradeInstrument">
            <key-map field-name="instrumentId"/>
        </relationship>
    </entity>

    <entity entity-name="ImportLcShippingGuarantee" package="trade.importlc">
        <field name="guaranteeId" type="id" is-pk="true"/>
        <field name="instrumentId" type="id"/>
        <field name="invoiceAmount" type="number-decimal"/>
        <field name="liabilityMultiplierRequired" type="number-integer" default="110"/> <!-- 110% per BRD -->
        <field name="transportDocReference" type="text-medium"/>
        <field name="guaranteeStatusId" type="id"/>
        <field name="sgStatusId" type="id"/>
        <field name="waiverLockFlag" type="text-indicator" default="'Y'"/>
        <field name="redemptionDate" type="date"/>
        <field name="issuanceFee" type="number-decimal"/>
        
        <relationship type="one" related="trade.importlc.ImportLetterOfCredit">
            <key-map field-name="instrumentId"/>
        </relationship>
    </entity>

    <entity entity-name="TradeDocumentPresentation" package="trade.importlc">
        <field name="presentationId" type="id" is-pk="true"/>
        <field name="instrumentId" type="id"/>
        <field name="presentationDate" type="date" default="ec.user.nowTimestamp"/>
        <field name="claimAmount" type="number-decimal"/>
        <field name="isDiscrepant" type="text-indicator"/>
        <field name="applicantDecisionEnumId" type="id"/> <!-- PENDING, WAIVED, REFUSED -->
        <field name="presentationStatusId" type="id"/>
        <field name="presentingBankRef" type="text-medium"/>
        <field name="claimCurrency" type="id"/>
        <field name="regulatoryDeadline" type="date"/>
        <field name="documentDisposalEnumId" type="id"/> <!-- Tag 77B: HOLDING_DOCUMENTS or RETURNING_DOCUMENTS -->
        <field name="chargesDeducted" type="text-long"/> <!-- Tag 73 -->
        <field name="senderToReceiverPresentationInfo" type="text-long"/> <!-- Tag 72Z -->
        
        <relationship type="one" related="trade.importlc.ImportLetterOfCredit">
            <key-map field-name="instrumentId"/>
        </relationship>
    </entity>

    <entity entity-name="TradeDocumentPresentationItem" package="trade.importlc">
        <field name="presentationId" type="id" is-pk="true"/>
        <field name="documentTypeEnumId" type="id" is-pk="true"/>
        <field name="originalsCount" type="number-integer"/>
        <field name="copiesCount" type="number-integer"/>
        
        <relationship type="one" related="trade.importlc.TradeDocumentPresentation">
            <key-map field-name="presentationId"/>
        </relationship>
    </entity>

    <entity entity-name="ImportLcAmendment" package="trade.importlc">
        <field name="amendmentId" type="id" is-pk="true"/>
        <field name="instrumentId" type="id"/>
        <field name="amendmentDate" type="date" default="ec.user.nowTimestamp"/>
        <field name="amountAdjustment" type="number-decimal" default="0"/>
        <field name="newExpiryDate" type="date"/>
        <field name="amendmentNarrative" type="text-very-long"/>
        <field name="isFinancial" type="text-indicator"/>
        <field name="beneficiaryConsentStatusId" type="id"/> <!-- PENDING, ACCEPTED, REJECTED -->
        <field name="amendmentBusinessStateId" type="id"/>
        <field name="amendmentTypeEnumId" type="id"/>
        <field name="isBeneficiaryAcceptanceRequired" type="text-indicator" default="'Y'"/>
        <field name="amendmentNumber" type="number-integer"/>
        <field name="newTolerance" type="number-decimal"/>
        <field name="chargeAllocationEnumId" type="id"/>
        
        <relationship type="one" related="trade.importlc.ImportLetterOfCredit">
            <key-map field-name="instrumentId"/>
        </relationship>
    </entity>

    <entity entity-name="PresentationDiscrepancy" package="trade.importlc">
        <field name="discrepancyId" type="id" is-pk="true"/>
        <field name="presentationId" type="id"/>
        <field name="discrepancyCode" type="text-short"/> <!-- ISBP standard code -->
        <field name="discrepancyDescription" type="text-long"/>
        <field name="isWaived" type="text-indicator" default="'N'"/>
        <field name="waivedByUserId" type="id"/>
        <field name="waivedTimestamp" type="date-time"/>
        
        <relationship type="one" related="trade.importlc.TradeDocumentPresentation">
            <key-map field-name="presentationId"/>
        </relationship>
    </entity>

    <entity entity-name="ImportLcSettlement" package="trade.importlc">
        <field name="settlementId" type="id" is-pk="true"/>
        <field name="presentationId" type="id"/>
        <field name="instrumentId" type="id"/>
        <field name="principalAmount" type="number-decimal"/>
        <field name="remittanceCurrency" type="id"/>
        <field name="valueDate" type="date"/>
        <field name="fxRate" type="number-decimal"/>
        <field name="localEquivalent" type="number-decimal"/>
        <field name="debitAccountId" type="text-medium"/>
        <field name="appliedMarginAmount" type="number-decimal" default="0"/>
        <field name="netDebitAmount" type="number-decimal"/>
        <field name="chargesDetailEnumId" type="id"/> <!-- OUR, BEN, SHA -->
        <field name="maturityDate" type="date"/> <!-- For Usance LCs -->
        <field name="settlementTypeEnumId" type="id"/> <!-- SIGHT, DEFERRED, ACCEPTANCE -->
        <field name="forwardContractRef" type="text-medium"/>
        <field name="settlementStatusId" type="id" default="'SETTLE_PENDING'"/>
        
        <relationship type="one" related="trade.importlc.TradeDocumentPresentation">
            <key-map field-name="presentationId"/>
        </relationship>
        <relationship type="one" related="trade.importlc.ImportLetterOfCredit">
            <key-map field-name="instrumentId"/>
        </relationship>
    </entity>

    <view-entity entity-name="ImportLetterOfCreditView" package="trade.importlc">
        <member-entity entity-alias="lc" entity-name="trade.importlc.ImportLetterOfCredit"/>
        <member-entity entity-alias="inst" entity-name="trade.TradeInstrument" join-from-alias="lc">
            <key-map field-name="instrumentId"/>
        </member-entity>
        <member-entity entity-alias="prio" entity-name="moqui.basic.Enumeration" join-from-alias="inst" join-optional="true">
            <key-map field-name="priorityEnumId" related="enumId"/>
        </member-entity>
        
        <!-- Junction Joins for Core Roles -->
        <member-entity entity-alias="appJunc" entity-name="trade.TradeInstrumentParty" join-from-alias="inst" join-optional="true">
            <key-map field-name="instrumentId"/>
            <entity-condition><econdition field-name="roleEnumId" value="TP_APPLICANT"/></entity-condition>
        </member-entity>
        <member-entity entity-alias="aparty" entity-name="trade.TradeParty" join-from-alias="appJunc" join-optional="true">
            <key-map field-name="partyId"/>
        </member-entity>

        <member-entity entity-alias="benJunc" entity-name="trade.TradeInstrumentParty" join-from-alias="inst" join-optional="true">
            <key-map field-name="instrumentId"/>
            <entity-condition><econdition field-name="roleEnumId" value="TP_BENEFICIARY"/></entity-condition>
        </member-entity>
        <member-entity entity-alias="bparty" entity-name="trade.TradeParty" join-from-alias="benJunc" join-optional="true">
            <key-map field-name="partyId"/>
        </member-entity>
        
        <member-entity entity-alias="tx" entity-name="trade.TradeTransaction" join-from-alias="inst" join-optional="true">
            <key-map field-name="instrumentId"/>
            <entity-condition><econdition field-name="transactionTypeEnumId" value="IMP_NEW"/></entity-condition>
        </member-entity>

        <alias-all entity-alias="lc"/>
        <alias-all entity-alias="inst">
            <exclude field="instrumentId"/>
            <exclude field="businessStateId"/>
        </alias-all>
        <alias-all entity-alias="tx">
            <exclude field="instrumentId"/>
            <exclude field="makerUserId"/>
            <exclude field="priorityEnumId"/>
        </alias-all>
        <alias entity-alias="prio" name="prioritySequence" field="sequenceNum"/>
        <alias entity-alias="aparty" name="applicantPartyName" field="partyName"/>
        <alias entity-alias="aparty" name="applicantPartyId" field="partyId"/>
        <alias entity-alias="bparty" name="beneficiaryPartyName" field="partyName"/>
        <alias entity-alias="bparty" name="beneficiaryPartyId" field="partyId"/>
    </view-entity>

    <entity entity-name="DummyTestEntity" package="trade.importlc">
        <field name="dummyId" type="id" is-pk="true"/>
    </entity>
</entities>
